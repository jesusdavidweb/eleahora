---
import Layout from '../layouts/Layout.astro';
import { getWorkshopPage, getSiteConfig } from '../lib/keystatic';

const workshop = await getWorkshopPage();
const site = await getSiteConfig();

const heroLabel = workshop?.heroLabel ?? 'Experiencia para empresas';
const heroTitle = workshop?.heroTitle ?? 'Pienso, luego medito.';
const heroSubtitle = workshop?.heroSubtitle ?? 'Transformando el estrés en presencia.';
const heroImage = workshop?.heroImage ?? '/images/Workshop Pienso Luego Medito-15-tiny.webp';
const heroImage2 = (workshop as any)?.heroImage2 ?? '/images/Workshop Pienso Luego Medito-92-tiny.webp';
const heroSecondaryCtaText = (workshop as any)?.heroSecondaryCtaText ?? 'Ver experiencia';
const heroSecondaryCtaLink = (workshop as any)?.heroSecondaryCtaLink ?? '#experiencia';
const heroAccessibleTitle = `"${heroTitle.replace(/\.$/, '')}"`;
const heroTitleClean = heroTitle.replace(/\.$/, '');
const heroTitleParts = heroTitleClean.split(', ');
const heroLine1 = heroTitleParts[0];
const heroLine2 = heroTitleParts.slice(1).join(', ');

const guideEyebrow = (workshop as any)?.guideEyebrow ?? 'Sobre la guía';
const guideName = (workshop as any)?.guideName ?? 'Maria Eleonora Corallo';
const guideBio = (workshop as any)?.guideBio ?? 'Terapeuta transpersonal, guía de meditación y fundadora de Eleahora. Combina su carrera de idiomas, PNL transpersonal, mindfulness y conexión energética para llevar herramientas prácticas de neuroregulación al entorno corporativo.';
const guideSlogan = (workshop as any)?.guideSlogan ?? 'Soy la voz que te recuerda que estás aquí.';

const workshopEyebrow = (workshop as any)?.workshopEyebrow ?? 'El workshop';
const workshopTitle = (workshop as any)?.workshopTitle ?? heroTitle;
const workshopDescription = (workshop as any)?.workshopDescription ?? `El workshop: "Pienso, luego medito" combina ciencia, introspección y técnicas prácticas para reconectar con nuestra esencia, regular nuestras emociones y vivir con mayor presencia.

El workshop guía a los asistentes a través de dinámicas envolventes que integran los cinco sentidos y los elementos de la naturaleza para cultivar la atención plena.

Además, aborda cómo nivelar el cortisol y la dopamina, dos hormonas clave en la productividad y el bienestar, ofreciendo herramientas como ejercicios de respiración, meditación y prácticas creativas.

Con un enfoque en la regulación del sistema nervioso, este espacio fomenta claridad mental, mejor toma de decisiones y una conexión más profunda entre los individuos y sus equipos.

Ideal para empresas que buscan empoderar a sus colaboradores con recursos para enfrentar los desafíos modernos, este workshop es más que una pausa: Es una invitación para transformar la manera en que vivimos y trabajamos, con una práctica tan esencial como la de volver al presente.`;
const experienceEyebrow = (workshop as any)?.experienceEyebrow ?? '¿Qué incluye la experiencia?';
const experienceTitle = (workshop as any)?.experienceTitle ?? 'Un recorrido práctico, consciente y aplicable.';
const experienceItems = (workshop as any)?.experienceItems?.length ? (workshop as any).experienceItems : [
  { title: "Bienvenida y aterrizaje consciente", description: "Apertura del espacio, intención compartida y práctica breve para llegar al aquí y ahora como equipo." },
  { title: "¿Cómo estar más presentes?", description: "Prácticas conscientes que integran los sentidos y los elementos." },
  { title: "Meditación como método de neuroregulación", description: "Sistema nervioso, dopamina y cortisol." },
  { title: "Meditación en todas sus formas", description: "Con el cuerpo, la mente y el alma." },
  { title: "Niño Interior", description: "Dinámicas lúdicas que despiertan la creatividad y la alegría." },
  { title: "¿Y ahora qué?", description: "Acciones concretas para aplicar en el día a día." }
];

const benefitsEyebrow = (workshop as any)?.benefitsEyebrow ?? '¿Qué te llevas como empresa?';
const benefitsTitle = workshop?.benefitsTitle ?? '¿Qué se llevan los equipos?';
const benefits = workshop?.benefits?.length ? workshop.benefits : [
  {
    title: 'Regulación del sistema nervioso',
    description: 'Herramientas prácticas para gestionar el estrés en el entorno laboral.',
  },
  {
    title: 'Mejora del foco y la concentración',
    description: 'Técnicas de atención plena aplicadas al rendimiento profesional.',
  },
  {
    title: 'Cohesión de equipo',
    description: 'Una experiencia compartida que fortalece los vínculos y la comunicación.',
  },
  {
    title: 'Reducción del absentismo',
    description: 'El bienestar emocional es una inversión que impacta directamente en la productividad y la retención del talento.',
  },
];
const ctaTitle = workshop?.ctaTitle ?? '¿Quieres llevar esta experiencia a tu organización?';
const ctaEyebrow = (workshop as any)?.ctaEyebrow ?? 'Siguiente paso';
const ctaButtonText = workshop?.ctaButtonText ?? 'Agendar llamada de descubrimiento';
const ctaButtonLink = (workshop as any)?.ctaButtonLink ?? '/contacto';
const ctaEmailLabel = (workshop as any)?.ctaEmailLabel ?? 'Escríbeme un correo';
const ctaEmailAddress = (workshop as any)?.ctaEmailAddress ?? 'info@eleahora.com';
const closingQuote = (workshop as any)?.closingQuote ?? 'El verdadero reto de la condición humana no es estar presente, sino darnos cuenta de que no estamos presentes.';
const closingQuoteAuthor = (workshop as any)?.closingQuoteAuthor ?? 'Meggan Watterson';

const testimonialsEyebrow = (workshop as any)?.testimonialsEyebrow ?? 'Quienes han vivido la experiencia';
const testimonialsTitle = (workshop as any)?.testimonialsTitle ?? 'Lo que ocurre cuando la pausa también es parte del proceso.';

type TestimonialData = {
  author: string;
  role: string;
  quote: string;
  color: string;
};

const testimonialColors = ['vinotinto', 'verde', 'morado'];
const testimonialsRaw = (workshop as any)?.testimonials;
const testimonialsData: TestimonialData[] = testimonialsRaw?.length
  ? testimonialsRaw.map((t: any, i: number) => ({
      author: t.name,
      role: t.role,
      quote: t.quote,
      color: testimonialColors[i % 3],
    }))
  : [
  {
    author: 'María Aristeguieta',
    role: 'Talent Processes Senior Specialist at Avature, Spain',
    quote: 'El profesionalismo y la calma de María marcan una verdadera diferencia. Practicar meditación después de su taller me ha ayudado muchísimo a ser más productiva y a ordenar mis prioridades con mayor claridad. También noto una mejor gestión del estrés en momentos de presión.',
    color: 'vinotinto',
  },
  {
    author: 'Vanessa Fernández',
    role: 'Senior Product Manager at Giftify, Belgium',
    quote: '¡Ojalá todos pudieran asistir a este workshop! Fue increíblemente valioso experimentar el mindfulness y llevarnos herramientas concretas para aplicar en el trabajo. Salimos con más presencia, mejor escucha y una energía de equipo mucho más conectada. ¡Tu workshop es oro puro!',
    color: 'verde',
  },
  {
    author: 'Stella Camacho',
    role: 'Founder & Chief Creative Officer at Amorchi House',
    quote: 'Gracias, Maria, por enseñarme que la pausa también es parte del proceso. Tu workshop me recordó que regularnos no es frenar, sino crear espacio para decidir mejor y colaborar con más empatía. Es una experiencia que realmente transforma la forma de vivir el día a día laboral.',
    color: 'morado',
  },
];

const whatsapp = site?.phoneWhatsapp ?? '+34605373782';
const waLink = `https://wa.me/${whatsapp.replace(/\D/g, '')}`;
const ctaHref = ctaButtonLink === '/contacto' ? '/contacto' : ctaButtonLink || waLink;

const workshopFacts = (workshop as any)?.facts?.length ? (workshop as any).facts : [
  { label: 'Formato', value: 'Team building', detail: 'aprox. 12 personas' },
  { label: 'Duración', value: '3 horas', detail: 'sesión intensiva' },
  { label: 'Modalidad', value: 'Presencial', detail: 'en tu empresa' },
];
---

<Layout
  title={(workshop as any)?.seoTitle ?? "Workshop 'Pienso, luego medito' | Mindfulness para Empresas | Eleahora"}
  description={(workshop as any)?.seoDescription ?? "Workshop de mindfulness y meditación para empresas y equipos. Programa 'Pienso, luego medito' de Eleahora: reduce el estrés, mejora el foco y fortalece la cohesión del equipo."}
  ogTitle={(workshop as any)?.ogTitle ?? "Workshop para Empresas — Eleahora"}
  ogImage={(workshop as any)?.ogImage ?? "/images/OG-images-eleahora-01.jpg"}
>
  <main class="workshop-page">
    <section class="workshop-hero" aria-labelledby="workshop-title">
      <div class="hero-glow" aria-hidden="true"></div>

      <div class="max-w-screen hero-grid">
        <figure class="hero-media" aria-hidden="true">
          <div class="hero-media-grid">
            <div class="hero-image-card hero-image-card-primary">
              <img
                src={heroImage}
                alt=""
                width="720"
                height="960"
                decoding="async"
                fetchpriority="high"
              />
            </div>
            <div class="hero-image-card hero-image-card-secondary">
              <img
                src={heroImage2}
                alt=""
                width="720"
                height="960"
                loading="eager"
                decoding="async"
              />
            </div>
          </div>
        </figure>

        <div class="hero-content">
          <span class="hero-tag">{heroLabel}</span>
          <h1 id="workshop-title" aria-label={heroAccessibleTitle}>
            <span class="hero-title-line hero-title-line--red" aria-hidden="true">"{heroLine1},</span>
            <span class="hero-title-line hero-title-line--dark" aria-hidden="true">{heroLine2}"</span>
          </h1>
          <p>{heroSubtitle}</p>

          <div class="hero-cta-row">
            <a href={ctaHref} class="btn-primary">{ctaButtonText}</a>
            <a href={heroSecondaryCtaLink} class="btn-outline">{heroSecondaryCtaText}</a>
          </div>

          <div class="hero-facts-row" aria-label="Datos del workshop">
            {workshopFacts.map((fact: { label: string; value: string; detail: string }) => (
              <div class="fact-chip">
                <span>{fact.label}</span>
                <strong>{fact.value}</strong>
                <em>{fact.detail}</em>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section-guide" aria-labelledby="guide-title">
      <div class="max-w-screen guide-grid">
        <div>
          <span class="eyebrow">{guideEyebrow}</span>
          <h2 id="guide-title">{guideName}</h2>
          <p>{guideBio}</p>
        </div>
        <figure class="guide-quote-block" aria-label="Slogan de Eleahora">
          <blockquote>
            <span>{guideSlogan}</span>
          </blockquote>
        </figure>
      </div>
    </section>

    <section class="section-about" aria-labelledby="about-title">
      <div class="max-w-screen about-grid">
        <header>
          <span class="eyebrow">{workshopEyebrow}</span>
          <h2 id="about-title">{workshopTitle}</h2>
        </header>
        <div>
          {workshopDescription.split('\n\n').filter(Boolean).map((p: string) => <p>{p}</p>)}
        </div>
      </div>
    </section>

    <section class="section-experience" id="experiencia" aria-labelledby="experience-title">
      <div class="max-w-screen">
        <header class="section-header">
          <span class="eyebrow">{experienceEyebrow}</span>
          <h2 id="experience-title">{experienceTitle}</h2>
        </header>

        <ol class="experience-list">
          {experienceItems.map((item: any, index: number) => (
            <li>
              <span>{String(index + 1).padStart(2, '0')}</span>
              <div>
                <h3>{typeof item === 'string' ? item : item.title}</h3>
                {typeof item !== 'string' && item.description && <p>{item.description}</p>}
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="section-benefits" aria-labelledby="benefits-title">
      <div class="max-w-screen benefits-inner">
        <header>
          <span class="eyebrow">{benefitsEyebrow}</span>
          <h2 id="benefits-title">{benefitsTitle}</h2>
        </header>

        <ul class="benefits-cards" aria-label="Beneficios para la empresa">
          {benefits.map((benefit: { title: string; description: string }, index: number) => (
            <li class={`benefit-card benefit-card--${['earth', 'sage', 'purple', 'red'][index % 4]}`}>
              <span aria-hidden="true"></span>
              <div>
                <h3>{benefit.title}</h3>
                <p>{benefit.description}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ─── TESTIMONIOS ───────────────────────────────────── -->
    <section class="section-testimonials" aria-labelledby="test-title">
      <div class="max-w-screen">
        <header class="section-header">
          <span class="eyebrow">{testimonialsEyebrow}</span>
          <h2 id="test-title">{testimonialsTitle}</h2>
        </header>

        <div class="testimonials-grid">
          {testimonialsData.map((t: TestimonialData, i: number) => (
            <blockquote class={`testimonial ${i === 0 ? 'testimonial--featured' : ''} testimonial--${t.color}`}>
              <div class="testimonial-quote-mark" aria-hidden="true">"</div>
              <p class="testimonial-text">{t.quote}</p>
              <footer class="testimonial-footer">
                <strong class="testimonial-author">{t.author}</strong>
                <span class="testimonial-role">{t.role}</span>
              </footer>
            </blockquote>
          ))}
        </div>
      </div>
    </section>

    <!-- Cita de cierre -->
    <section class="section-closing-quote" aria-label="Cita de cierre">
      <div class="max-w-screen closing-quote-inner">
        <blockquote>
          <p>"{closingQuote}"</p>
          <cite>— {closingQuoteAuthor}</cite>
        </blockquote>
      </div>
    </section>

    <section class="section-cta section-soft" aria-labelledby="cta-title">
      <div class="max-w-screen cta-inner">
        <p class="text-accent">{ctaEyebrow}</p>
        <h2 id="cta-title">{ctaTitle}</h2>
        <div class="cta-actions">
          <a href={site?.calLink ?? ctaHref} class="btn-primary">{ctaButtonText}</a>
          <a href={`mailto:${ctaEmailAddress}`} class="btn-outline">{ctaEmailLabel}</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .workshop-page {
    padding-top: 6rem;
    overflow-x: hidden;
  }

  .workshop-hero {
    position: relative;
    padding: 6.4rem 0 5rem;
    isolation: isolate;
    overflow: hidden;
    background:
      radial-gradient(ellipse 58% 42% at 62% 10%, rgba(59, 38, 57, 0.12) 0%, transparent 62%),
      radial-gradient(ellipse 46% 38% at 8% 72%, rgba(187, 137, 107, 0.12) 0%, transparent 58%),
      var(--color-background);
  }

  .hero-glow {
    position: absolute;
    top: -80px;
    left: 50%;
    z-index: -1;
    width: 900px;
    height: 500px;
    border-radius: 999px;
    background: radial-gradient(ellipse at center, rgba(109, 68, 146, 0.12), rgba(187, 137, 107, 0.08) 40%, transparent 70%);
    filter: blur(60px);
    transform: translateX(-50%);
    animation: heroGlowFloat 10s ease-in-out infinite;
  }

  .hero-grid {
    position: relative;
    z-index: 1;
    width: min(86.5vw, 1768px);
    max-width: none;
    padding: 0;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.9fr);
    grid-template-areas: "content media";
    gap: clamp(2rem, 4vw, 4rem);
    align-items: center;
  }

  .hero-media {
    grid-area: media;
    margin: 0;
    align-self: stretch;
  }

  .hero-media-grid {
    position: relative;
    min-height: clamp(500px, 44vw, 620px);
  }

  .hero-image-card {
    border: 1px solid rgba(59, 38, 57, 0.12);
    border-radius: 24px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.48);
    box-shadow: 0 24px 64px rgba(59, 38, 57, 0.13), inset 0 1px 0 rgba(255, 255, 255, 0.5);
    transition: transform 0.35s ease, box-shadow 0.35s ease;
  }

  .hero-image-card:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 28px 60px rgba(59, 38, 57, 0.18), inset 0 1px 0 rgba(255, 255, 255, 0.62);
  }

  .hero-image-card img {
    display: block;
    width: 100%;
    height: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .hero-image-card-primary {
    position: absolute;
    top: 0;
    right: 0;
    width: min(100%, 650px);
  }

  .hero-image-card-secondary {
    position: absolute;
    right: 0;
    bottom: 0;
    z-index: 2;
    width: min(82%, 540px);
  }

  .hero-content {
    grid-area: content;
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    min-height: clamp(520px, 45vw, 640px);
    padding: clamp(2rem, 3.4vw, 3.4rem) clamp(1.65rem, 3.3vw, 3rem);
    border-radius: 26px;
  }

  .hero-content::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: inherit;
    background:
      linear-gradient(110deg, rgba(253, 251, 236, 0.92) 0%, rgba(253, 251, 236, 0.78) 54%, rgba(253, 251, 236, 0.6) 100%),
      radial-gradient(ellipse 120% 95% at 20% 15%, rgba(253, 251, 236, 0.5) 0%, transparent 66%);
    border: 1px solid rgba(255, 255, 255, 0.72);
    box-shadow: 0 28px 72px rgba(59, 38, 57, 0.11), inset 0 1px 0 rgba(255, 255, 255, 0.82);
    backdrop-filter: blur(3px);
  }

  .hero-tag {
    display: inline-block;
    margin-bottom: 2rem;
    padding: 0.4rem 1.1rem;
    border: 1px solid rgba(59, 38, 57, 0.18);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.55);
    color: rgba(59, 38, 57, 0.75);
    font-family: var(--font-base);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .hero-content h1 {
    margin: 0 0 1.2rem;
    font-size: clamp(3.45rem, 5.8vw, 6.45rem);
    line-height: 0.93;
    letter-spacing: 0;
  }

  .hero-title-line {
    display: block;
    font-style: normal;
    white-space: nowrap;
  }

  .hero-title-line--red {
    color: var(--color-accent-red);
  }

  .hero-title-line--dark {
    color: var(--color-primary-dark);
  }

  .hero-content p {
    max-width: 38ch;
    margin: 0 0 2.4rem;
    color: rgba(59, 38, 57, 0.66);
    font-size: clamp(1.02rem, 1.5vw, 1.28rem);
    line-height: 1.35;
  }

  .hero-cta-row {
    display: flex;
    flex-wrap: nowrap;
    gap: 1.2rem;
    margin-bottom: clamp(2.8rem, 4.8vw, 4.6rem);
  }

  .hero-cta-row :global(a) {
    padding-inline: clamp(1.65rem, 2.35vw, 2.5rem);
  }

  .hero-facts-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    width: 100%;
    margin-top: auto;
  }

  .hero-facts-row .fact-chip {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
    min-height: 112px;
    padding: 1.35rem 1.2rem;
    border: 1px solid rgba(59, 38, 57, 0.09);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.68);
    box-shadow: 0 14px 32px rgba(59, 38, 57, 0.07), inset 0 1px 0 rgba(255, 255, 255, 0.82);
  }

  .hero-facts-row .fact-chip span {
    color: rgba(59, 38, 57, 0.5);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .hero-facts-row .fact-chip strong {
    color: var(--color-primary-dark);
    font-family: var(--font-primary);
    font-size: clamp(1.12rem, 1.45vw, 1.45rem);
    line-height: 1.08;
  }

  .hero-facts-row .fact-chip em {
    color: rgba(59, 38, 57, 0.5);
    font-size: 0.78rem;
    line-height: 1.25;
  }

  .eyebrow {
    display: block;
    margin-bottom: 0.9rem;
    color: var(--color-accent-red);
    font-family: var(--font-base);
    font-size: 0.73rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .section-guide,
  .section-about,
  .section-experience,
  .section-benefits,
  .section-formats {
    padding: 5rem 0;
  }

  .section-guide {
    position: relative;
    overflow: hidden;
    background: var(--color-accent-red);
  }

  .section-guide::before {
    content: "";
    position: absolute;
    top: -100px;
    right: -100px;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(187, 137, 107, 0.18), transparent 65%);
  }

  .guide-grid,
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .section-guide .eyebrow {
    color: var(--color-earth);
  }

  .section-guide h2,
  .section-guide p {
    color: var(--color-background);
  }

  .section-guide h2,
  .about-grid h2,
  .section-header h2,
  .section-benefits h2,
  .cta-inner h2 {
    margin: 0;
    font-size: clamp(2.2rem, 4.5vw, 4rem);
    line-height: 1.04;
    letter-spacing: 0;
  }

  .section-guide p,
  .about-grid p {
    margin: 0;
    font-size: 1.08rem;
    line-height: 1.8;
  }

  .guide-quote-block {
    display: flex;
    justify-content: center;
    margin: 0;
  }

  .guide-quote-block blockquote {
    margin: 0;
    padding: 2.5rem 2rem;
    border-left: 3px solid var(--color-earth);
  }

  .guide-quote-block span {
    color: var(--color-earth);
    font-family: var(--font-primary);
    font-size: clamp(2rem, 4.5vw, 4rem);
    line-height: 1.05;
    text-transform: lowercase;
  }

  .guide-quote-block span::first-letter {
    font-family: var(--font-accent);
    text-transform: uppercase;
    font-size: 1.5em;
  }

  .section-about,
  .section-experience {
    background:
      radial-gradient(ellipse 70% 50% at 95% 50%, rgba(109, 68, 146, 0.06), transparent 55%),
      var(--color-background);
  }

  .about-grid {
    align-items: start;
  }

  .section-testimonials {
    padding: 5rem 0;
    background:
      radial-gradient(ellipse 70% 60% at 95% 20%, rgba(140, 7, 3, 0.07), transparent 55%),
      var(--color-background);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 1.2rem;
    align-items: start;
  }

  .testimonial {
    margin: 0;
    padding: 2rem 2.2rem;
    border-radius: 24px;
    border: 1px solid rgba(59, 38, 57, 0.1);
    background: rgba(255, 255, 255, 0.7);
    box-shadow: 0 16px 40px rgba(59, 38, 57, 0.06), inset 0 1px 0 rgba(255, 255, 255, 0.9);
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
