---
import Layout from '../layouts/Layout.astro';
import { getWorkshopPage, getSiteConfig } from '../lib/keystatic';

const workshop = await getWorkshopPage();
const site = await getSiteConfig();

const heroLabel = workshop?.heroLabel ?? 'Workshop para empresas';
const heroTitle = workshop?.heroTitle ?? 'Pienso, luego medito.';
const heroSubtitle = workshop?.heroSubtitle ?? 'Una experiencia de mindfulness y meditación diseñada para equipos y organizaciones que quieren reducir el estrés y potenciar el rendimiento.';
const heroImage = workshop?.heroImage ?? '/images/Workshop Pienso Luego Medito-15-tiny.webp';
const heroImage2 = (workshop as any)?.heroImage2 ?? '/images/Workshop Pienso Luego Medito-92-tiny.webp';
const heroSecondaryCtaText = (workshop as any)?.heroSecondaryCtaText ?? 'Ver formatos';
const heroSecondaryCtaLink = (workshop as any)?.heroSecondaryCtaLink ?? '#formatos';

const guideEyebrow = (workshop as any)?.guideEyebrow ?? 'Sobre la guía';
const guideName = (workshop as any)?.guideName ?? 'Maria Eleonora Corallo';
const guideBio = (workshop as any)?.guideBio ?? 'Terapeuta transpersonal, guía de meditación y fundadora de Eleahora. Combina su carrera de idiomas, PNL transpersonal, mindfulness y conexión energética para llevar herramientas prácticas de neuroregulación al entorno corporativo.';
const guideSlogan = (workshop as any)?.guideSlogan ?? 'Soy la voz que te recuerda que estás aquí.';

const workshopEyebrow = (workshop as any)?.workshopEyebrow ?? 'El workshop';
const workshopTitle = (workshop as any)?.workshopTitle ?? heroTitle;
const workshopDescription = (workshop as any)?.workshopDescription ?? `El workshop: "Pienso, luego medito" combina ciencia, introspección y técnicas prácticas para reconectar con nuestra esencia, regular nuestras emociones y vivir con mayor presencia.
El workshop guía a los asistentes a través de dinámicas envolventes que integran los cinco sentidos y los elementos de la naturaleza para cultivar la atención plena. Además, aborda cómo nivelar el cortisol y la dopamina, dos hormonas clave en la productividad y el bienestar, ofreciendo herramientas como ejercicios de respiración, meditación y prácticas creativas.
Con un enfoque en la regulación del sistema nervioso, este espacio fomenta claridad mental, mejor toma de decisiones y una conexión más profunda entre los individuos y sus equipos.
Ideal para empresas que buscan empoderar a sus colaboradores con recursos para enfrentar los desafíos modernos, este workshop es más que una pausa: Es una invitación para transformar la manera en que vivimos y trabajamos, con una práctica tan esencial como la de volver al presente.`;
const experienceEyebrow = (workshop as any)?.experienceEyebrow ?? '¿Qué incluye la experiencia?';
const experienceTitle = (workshop as any)?.experienceTitle ?? 'Un recorrido práctico, consciente y aplicable.';
const experienceItems = (workshop as any)?.experienceItems?.length ? (workshop as any).experienceItems : [
  { title: "Bienvenida y aterrizaje consciente", description: "Apertura del espacio, intención compartida y práctica breve para llegar al aquí y ahora como equipo." },
  { title: "¿Cómo estar más presentes?", description: "Prácticas conscientes que integran los sentidos y los elementos." },
  { title: "Meditación como método de neuroregulación", description: "Sistema nervioso, dopamina y cortisol." },
  { title: "Meditación en todas sus formas", description: "Con el cuerpo, la mente y el alma." },
  { title: "Niño Interior", description: "Dinámicas lúdicas que despiertan la creatividad y la alegría." },
  { title: "¿Y ahora qué?", description: "Acciones concretas para aplicar en el día a día." }
];

const benefitsEyebrow = (workshop as any)?.benefitsEyebrow ?? '¿Qué te llevas como empresa?';
const benefitsTitle = workshop?.benefitsTitle ?? '¿Qué se llevan los equipos?';
const benefits = workshop?.benefits?.length ? workshop.benefits : [
  {
    title: 'Regulación del sistema nervioso',
    description: 'Herramientas prácticas para gestionar el estrés en el entorno laboral.',
  },
  {
    title: 'Mejora del foco y la concentración',
    description: 'Técnicas de atención plena aplicadas al rendimiento profesional.',
  },
  {
    title: 'Cohesión de equipo',
    description: 'Una experiencia compartida que fortalece los vínculos y la comunicación.',
  },
  {
    title: 'Reducción del absentismo',
    description: 'El bienestar emocional es una inversión que impacta directamente en la productividad y la retención del talento.',
  },
];
const ctaTitle = workshop?.ctaTitle ?? '¿Hablamos para tu empresa?';
const ctaBody = workshop?.ctaBody ?? 'Cuéntame el tamaño de tu equipo y qué necesitáis, y diseñamos juntos la experiencia perfecta.';
const ctaEyebrow = (workshop as any)?.ctaEyebrow ?? 'Siguiente paso';
const ctaButtonText = workshop?.ctaButtonText ?? 'Solicitar información';
const ctaButtonLink = (workshop as any)?.ctaButtonLink ?? '/contacto';
const whatsappCtaText = (workshop as any)?.whatsappCtaText ?? 'WhatsApp';

const whatsapp = site?.phoneWhatsapp ?? '+34605373782';
const waLink = `https://wa.me/${whatsapp.replace(/\D/g, '')}`;
const ctaHref = ctaButtonLink === '/contacto' ? '/contacto' : ctaButtonLink || waLink;

const workshopFacts = (workshop as any)?.facts?.length ? (workshop as any).facts : [
  { label: 'Formato', value: 'Empresas', detail: 'equipos y organizaciones' },
  { label: 'Modalidad', value: 'Presencial', detail: 'adaptable a tu equipo' },
  { label: 'Enfoque', value: 'Mindfulness', detail: 'práctico y aplicable' },
];
---

<Layout
  title={(workshop as any)?.seoTitle ?? "Workshop 'Pienso, luego medito' | Mindfulness para Empresas | Eleahora"}
  description={(workshop as any)?.seoDescription ?? "Workshop de mindfulness y meditación para empresas y equipos. Programa 'Pienso, luego medito' de Eleahora: reduce el estrés, mejora el foco y fortalece la cohesión del equipo."}
  ogTitle={(workshop as any)?.ogTitle ?? "Workshop para Empresas — Eleahora"}
  ogImage={(workshop as any)?.ogImage ?? "/images/OG-images-eleahora-01.jpg"}
>
  <main class="workshop-page">
    <section class="workshop-hero" aria-labelledby="workshop-title">
      <div class="hero-glow" aria-hidden="true"></div>

      <div class="max-w-screen hero-grid">
        <figure class="hero-media" aria-hidden="true">
          <div class="hero-media-grid">
            <div class="hero-image-card hero-image-card-primary">
              <img
                src={heroImage}
                alt=""
                width="720"
                height="960"
                decoding="async"
                fetchpriority="high"
              />
            </div>
            <div class="hero-image-card hero-image-card-secondary">
              <img
                src={heroImage2}
                alt=""
                width="720"
                height="960"
                loading="eager"
                decoding="async"
              />
            </div>
          </div>
        </figure>

        <div class="hero-content">
          <span class="hero-tag">{heroLabel}</span>
          <h1 id="workshop-title">
            <em>{heroTitle}</em>
          </h1>
          <p>{heroSubtitle}</p>

          <div class="hero-cta-row">
            <a href={ctaHref} class="btn-primary">{ctaButtonText}</a>
            <a href={heroSecondaryCtaLink} class="btn-outline">{heroSecondaryCtaText}</a>
          </div>

          <ul class="hero-facts" aria-label="Datos del workshop">
            {workshopFacts.map((fact: { label: string; value: string; detail: string }) => (
              <li class="fact-chip">
                <span>{fact.label}</span>
                <strong>{fact.value}</strong>
                <small>{fact.detail}</small>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="section-guide" aria-labelledby="guide-title">
      <div class="max-w-screen guide-grid">
        <div>
          <span class="eyebrow">{guideEyebrow}</span>
          <h2 id="guide-title">{guideName}</h2>
          <p>{guideBio}</p>
        </div>
        <figure class="guide-quote-block" aria-label="Slogan de Eleahora">
          <blockquote>
            <span>{guideSlogan}</span>
          </blockquote>
        </figure>
      </div>
    </section>

    <section class="section-about" aria-labelledby="about-title">
      <div class="max-w-screen about-grid">
        <header>
          <span class="eyebrow">{workshopEyebrow}</span>
          <h2 id="about-title">{workshopTitle}</h2>
        </header>
        <div>
          {workshopDescription.split('\n\n').filter(Boolean).map(p => <p>{p}</p>)}
          <div class="about-facts-row" aria-label="Detalles del workshop">
            {workshopFacts.map((fact: { label: string; value: string; detail: string }) => (
              <div>
                <span>{fact.label}</span>
                <strong>{fact.value}</strong>
                <em>{fact.detail}</em>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section-experience" aria-labelledby="experience-title">
      <div class="max-w-screen">
        <header class="section-header">
          <span class="eyebrow">{experienceEyebrow}</span>
          <h2 id="experience-title">{experienceTitle}</h2>
        </header>

        <ol class="experience-list">
          {experienceItems.map((item: any, index: number) => (
            <li>
              <span>{String(index + 1).padStart(2, '0')}</span>
              <div>
                <h3>{typeof item === 'string' ? item : item.title}</h3>
                {typeof item !== 'string' && item.description && <p>{item.description}</p>}
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="section-benefits" aria-labelledby="benefits-title">
      <div class="max-w-screen benefits-inner">
        <header>
          <span class="eyebrow">{benefitsEyebrow}</span>
          <h2 id="benefits-title">{benefitsTitle}</h2>
        </header>

        <ul class="benefits-cards" aria-label="Beneficios para la empresa">
          {benefits.map((benefit: { title: string; description: string }, index: number) => (
            <li class={`benefit-card benefit-card--${['earth', 'sage', 'purple', 'red'][index % 4]}`}>
              <span aria-hidden="true"></span>
              <div>
                <h3>{benefit.title}</h3>
                <p>{benefit.description}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="section-cta section-soft" aria-labelledby="cta-title">
      <div class="max-w-screen cta-inner">
        <p class="text-accent">{ctaEyebrow}</p>
        <h2 id="cta-title">{ctaTitle}</h2>
        <p>{ctaBody}</p>
        <div class="cta-actions">
          <a href={ctaHref} class="btn-primary">{ctaButtonText}</a>
          <a href={waLink} target="_blank" rel="noopener noreferrer" class="btn-outline">{whatsappCtaText}</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .workshop-page {
    padding-top: 6rem;
    overflow-x: hidden;
  }

  .workshop-hero {
    position: relative;
    padding: 8rem 0 6rem;
    isolation: isolate;
    overflow: hidden;
    background:
      radial-gradient(ellipse 80% 60% at 60% -10%, rgba(109, 68, 146, 0.18) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at -5% 80%, rgba(187, 137, 107, 0.14) 0%, transparent 55%),
      var(--color-background);
  }

  .hero-glow {
    position: absolute;
    top: -80px;
    left: 50%;
    z-index: -1;
    width: 900px;
    height: 500px;
    border-radius: 999px;
    background: radial-gradient(ellipse at center, rgba(109, 68, 146, 0.12), rgba(187, 137, 107, 0.08) 40%, transparent 70%);
    filter: blur(60px);
    transform: translateX(-50%);
    animation: heroGlowFloat 10s ease-in-out infinite;
  }

  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    grid-template-areas: "content media";
    gap: 2.5rem;
    align-items: center;
  }

  .hero-media {
    grid-area: media;
    margin: 0;
  }

  .hero-media-grid {
    display: grid;
    gap: 1rem;
  }

  .hero-image-card {
    border: 1px solid rgba(59, 38, 57, 0.12);
    border-radius: 22px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.48);
    box-shadow: 0 20px 46px rgba(59, 38, 57, 0.14), inset 0 1px 0 rgba(255, 255, 255, 0.5);
    transform: translateY(var(--card-offset-y, 0)) rotate(var(--card-rotate, 0));
    transition: transform 0.35s ease, box-shadow 0.35s ease;
  }

  .hero-image-card:hover {
    transform: translateY(var(--card-offset-y, 0)) rotate(var(--card-rotate, 0)) scale(1.04);
    box-shadow: 0 28px 60px rgba(59, 38, 57, 0.18), inset 0 1px 0 rgba(255, 255, 255, 0.62);
  }

  .hero-image-card img {
    display: block;
    width: 100%;
    height: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .hero-image-card-primary {
    --card-rotate: -1.2deg;
  }

  .hero-image-card-secondary {
    --card-offset-y: -12%;
    --card-rotate: 2deg;
    max-width: 82%;
    justify-self: end;
  }

  .hero-content {
    grid-area: content;
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 2.4rem 2.1rem;
    border-radius: 26px;
  }

  .hero-content::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: inherit;
    background:
      linear-gradient(110deg, rgba(253, 251, 236, 0.86) 0%, rgba(253, 251, 236, 0.72) 48%, rgba(253, 251, 236, 0.52) 100%),
      radial-gradient(ellipse 120% 95% at 20% 15%, rgba(253, 251, 236, 0.5) 0%, transparent 66%);
    box-shadow: 0 20px 50px rgba(59, 38, 57, 0.11), inset 0 1px 0 rgba(255, 255, 255, 0.78);
    backdrop-filter: blur(3px);
  }

  .hero-tag {
    display: inline-block;
    margin-bottom: 2rem;
    padding: 0.4rem 1.1rem;
    border: 1px solid rgba(59, 38, 57, 0.18);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.55);
    color: rgba(59, 38, 57, 0.75);
    font-family: var(--font-base);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .hero-content h1 {
    margin: 0 0 1.15rem;
    color: var(--color-accent-red);
    font-size: clamp(2.4rem, 5.6vw, 4.8rem);
    line-height: 0.98;
    letter-spacing: 0;
  }

  .hero-content h1 em {
    font-style: normal;
  }

  .hero-content p {
    max-width: 38ch;
    margin: 0 0 2.1rem;
    color: rgba(59, 38, 57, 0.78);
    font-size: clamp(1.02rem, 1.5vw, 1.28rem);
    line-height: 1.55;
  }

  .hero-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 3.5rem;
  }

  .hero-facts {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .fact-chip {
    display: flex;
    min-width: 160px;
    flex-direction: column;
    gap: 0.15rem;
    padding: 1.1rem 1.5rem;
    border: 1px solid rgba(59, 38, 57, 0.1);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.6);
    box-shadow: 0 8px 24px rgba(59, 38, 57, 0.05), inset 0 1px 0 rgba(255, 255, 255, 0.9);
  }

  .fact-chip span {
    color: rgba(59, 38, 57, 0.5);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .fact-chip strong {
    color: var(--color-primary-dark);
    font-family: var(--font-primary);
    font-size: 1.25rem;
    line-height: 1.15;
  }

  .fact-chip small {
    color: rgba(59, 38, 57, 0.55);
    font-size: 0.8rem;
    font-style: italic;
  }

  .eyebrow {
    display: block;
    margin-bottom: 0.9rem;
    color: var(--color-accent-red);
    font-family: var(--font-base);
    font-size: 0.73rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .section-guide,
  .section-about,
  .section-experience,
  .section-benefits,
  .section-formats {
    padding: 5rem 0;
  }

  .section-guide {
    position: relative;
    overflow: hidden;
    background: var(--color-accent-red);
  }

  .section-guide::before {
    content: "";
    position: absolute;
    top: -100px;
    right: -100px;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(187, 137, 107, 0.18), transparent 65%);
  }

  .guide-grid,
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .section-guide .eyebrow {
    color: var(--color-earth);
  }

  .section-guide h2,
  .section-guide p {
    color: var(--color-background);
  }

  .section-guide h2,
  .about-grid h2,
  .section-header h2,
  .section-benefits h2,
  .cta-inner h2 {
    margin: 0;
    font-size: clamp(2.2rem, 4.5vw, 4rem);
    line-height: 1.04;
    letter-spacing: 0;
  }

  .section-guide p,
  .about-grid p {
    margin: 0;
    font-size: 1.08rem;
    line-height: 1.8;
  }

  .guide-quote-block {
    display: flex;
    justify-content: center;
    margin: 0;
  }

  .guide-quote-block blockquote {
    margin: 0;
    padding: 2.5rem 2rem;
    border-left: 3px solid var(--color-earth);
  }

  .guide-quote-block span {
    color: var(--color-earth);
    font-family: var(--font-primary);
    font-size: clamp(2rem, 4.5vw, 4rem);
    line-height: 1.05;
    text-transform: lowercase;
  }

  .guide-quote-block span::first-letter {
    font-family: var(--font-accent);
    text-transform: uppercase;
    font-size: 1.5em;
  }

  .section-about,
  .section-experience {
    background:
      radial-gradient(ellipse 70% 50% at 95% 50%, rgba(109, 68, 146, 0.06), transparent 55%),
      var(--color-background);
  }

  .about-grid {
    align-items: start;
  }

  .about-facts-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin-top: 2.5rem;
    overflow: hidden;
    border: 1px solid rgba(59, 38, 57, 0.1);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.65);
    box-shadow: 0 12px 30px rgba(59, 38, 57, 0.06);
  }

  .about-facts-row div {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1.4rem 1.2rem;
    border-right: 1px solid rgba(59, 38, 57, 0.1);
  }

  .about-facts-row div:last-child {
    border-right: none;
  }

  .about-facts-row span {
    color: rgba(59, 38, 57, 0.5);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .about-facts-row strong {
    color: var(--color-primary-dark);
    font-family: var(--font-primary);
    font-size: 1.3rem;
  }

  .about-facts-row em {
    color: rgba(59, 38, 57, 0.5);
    font-size: 0.78rem;
  }

  .section-header {
    max-width: 780px;
    margin-bottom: 3rem;
  }

  .experience-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    padding: 0;
    margin: 0;
    overflow: hidden;
    border: 1px solid rgba(59, 38, 57, 0.1);
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.5);
    box-shadow: 0 24px 60px rgba(59, 38, 57, 0.07), inset 0 1px 0 rgba(255, 255, 255, 0.9);
    list-style: none;
  }

  .experience-list li {
    display: flex;
    gap: 1.4rem;
    padding: 2rem 2.2rem;
    border-right: 1px solid rgba(59, 38, 57, 0.08);
    border-bottom: 1px solid rgba(59, 38, 57, 0.08);
    background: rgba(255, 255, 255, 0.55);
  }

  .experience-list li:nth-child(even) {
    border-right: none;
  }

  .experience-list li:nth-last-child(-n+2) {
    border-bottom: none;
  }

  .experience-list > li > span {
    display: inline-flex;
    width: 2.8rem;
    height: 2.8rem;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--color-primary-dark);
    color: var(--color-background);
    font-family: var(--font-primary);
    font-size: 0.8rem;
  }

  .experience-list h3,
  .benefit-card h3 {
    margin: 0 0 0.45rem;
    color: var(--color-primary-dark);
    font-size: 1.2rem;
    line-height: 1.2;
  }

  .experience-list p,
  .benefit-card p {
    margin: 0;
    line-height: 1.7;
  }

  .section-benefits {
    position: relative;
    overflow: hidden;
    background: var(--color-primary-dark);
  }

  .section-benefits::after {
    content: "";
    position: absolute;
    bottom: -120px;
    left: -80px;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(109, 68, 146, 0.2), transparent 65%);
  }

  .benefits-inner {
    position: relative;
    z-index: 1;
  }

  .section-benefits .eyebrow {
    color: var(--color-earth);
  }

  .section-benefits h2 {
    max-width: 22ch;
    margin-bottom: 3rem;
    color: var(--color-background);
  }

  .benefits-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    padding: 0;
    margin: 0;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.04);
    list-style: none;
  }

  .benefit-card {
    display: flex;
    gap: 1.2rem;
    padding: 2.2rem 2.5rem;
    border-right: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(255, 255, 255, 0.04);
  }

  .benefit-card:nth-child(even) {
    border-right: none;
  }

  .benefit-card:nth-last-child(-n+2) {
    border-bottom: none;
  }

  .benefit-card > span {
    width: 10px;
    height: 10px;
    flex-shrink: 0;
    margin-top: 0.6rem;
    border-radius: 50%;
  }

  .benefit-card--earth > span { background: var(--color-earth); }
  .benefit-card--sage > span { background: var(--color-sage); }
  .benefit-card--purple > span { background: var(--color-accent-purple); }
