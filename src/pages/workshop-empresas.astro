---
import Layout from "../layouts/Layout.astro";
import { getWorkshopPage } from "../lib/keystatic";

// Keystatic: datos del CMS
const workshop = await getWorkshopPage();

// Fallbacks
const heroLabel = workshop?.heroLabel ?? "Experiencia para Empresas";
const heroTitle = workshop?.heroTitle ?? "Pienso, luego medito";
const heroSubtitle = workshop?.heroSubtitle ?? "Transformando el estrés en presencia.";
const heroImage = workshop?.heroImage ?? "/images/Workshop Pienso Luego Medito-15-tiny.webp";
const heroImage2 = (workshop as any)?.heroImage2 ?? "/images/Workshop Pienso Luego Medito-92-tiny.webp";
const heroImageAlt = (workshop as any)?.heroImageAlt ?? "Participantes en dinámica de mindfulness corporativo";
const heroImage2Alt = (workshop as any)?.heroImage2Alt ?? "Sesión de meditación guiada para equipos";
const heroTitleParts = heroTitle.replace(/\.$/, "").split(",");
const heroTitleFirst = `"${heroTitleParts[0]}${heroTitleParts.length > 1 ? "," : '"'}`;
const heroTitleRest = heroTitleParts.length > 1 ? `${heroTitleParts.slice(1).join(",").trim()}"` : "";

const guideName = (workshop as any)?.guideName ?? "Maria Eleonora Corallo";
const guideBio = (workshop as any)?.guideBio ?? "Terapeuta transpersonal, guía de meditación y fundadora de Eleahora. Combina su carrera de idiomas (La Sorbonne) y su formación en PNL transpersonal, Mindfulness y conexión energética para llevar herramientas prácticas de neuroregulación al entorno corporativo.";
const guideSlogan = (workshop as any)?.guideSlogan ?? "Soy La Voz\nQUE TE RECUERDA\nQUE ESTÁS AQUÍ.";
const guideSloganLines = guideSlogan.split("\n");
const guideSloganAccent = guideSloganLines[0] ?? "Soy La Voz";
const guideSloganMain = guideSloganLines.slice(1).join("\n");

const workshopTitle = (workshop as any)?.workshopTitle ?? "Creado para transformar cómo los equipos perciben y manejan el estrés.";
const workshopDescription = (workshop as any)?.workshopDescription ?? "\"Pienso, luego medito\" combina ciencia, introspección y técnicas prácticas para reconectar con nuestra esencia, regular nuestras emociones y vivir con mayor presencia. El workshop guía a los asistentes a través de dinámicas envolventes que integran los cinco sentidos y los elementos de la naturaleza para cultivar la atención plena. Además, aborda cómo nivelar el cortisol y la dopamina, dos hormonas clave en la productividad y el bienestar, ofreciendo herramientas como ejercicios de respiración, meditación y prácticas creativas. Con un enfoque en la regulación del sistema nervioso, este espacio fomenta claridad mental, mejor toma de decisiones y una conexión más profunda entre los individuos y sus equipos. Ideal para empresas que buscan empoderar a sus colaboradores con recursos para enfrentar los desafíos modernos, este workshop es más que una pausa: Es una invitación para transformar la manera en que vivimos y trabajamos, con una práctica tan esencial como la de volver al presente.";

const experienceTitle = (workshop as any)?.experienceTitle ?? "Un recorrido práctico, consciente y aplicable.";
const experienceItems = (workshop as any)?.experienceItems?.length ? (workshop as any).experienceItems : [
  { title: "Bienvenida y aterrizaje consciente", description: "Apertura del espacio, intención compartida y práctica breve para llegar al aquí y ahora como equipo." },
  { title: "¿Cómo estar más presentes?", description: "Prácticas conscientes que integran los sentidos y los elementos." },
  { title: "Meditación como método de neuroregulación", description: "Sistema nervioso, dopamina y cortisol." },
  { title: "Meditación en todas sus formas", description: "Con el cuerpo, la mente y el alma." },
  { title: "Niño Interior", description: "Dinámicas lúdicas que despiertan la creatividad y la alegría." },
  { title: "¿Y ahora qué?", description: "Acciones concretas para aplicar en el día a día." }
];

const benefitsTitle = (workshop as any)?.benefitsTitle ?? "Lo que cambia después de la experiencia.";
const companyBenefits = workshop?.benefits?.length ? workshop.benefits : [
  { description: "Herramientas prácticas para regular altos niveles de estrés." },
  { description: "Mejor sinergia grupal, empatía y conexión." },
  { description: "Mayor claridad en la toma de decisiones." },
  { description: "Información valiosa para cultivar la mente y potenciar el rendimiento." }
];

const testimonialsTitle = (workshop as any)?.testimonialsTitle ?? "Lo que ocurre cuando la pausa también es parte del proceso.";
const testimonialsEyebrow = (workshop as any)?.testimonialsEyebrow ?? "Quienes han vivido la experiencia";
const testimonials = (workshop as any)?.testimonials?.length ? (workshop as any).testimonials : [
  {
    quote: "El profesionalismo y la calma de María marcan una verdadera diferencia. Practicar meditación después de su taller me ha ayudado muchísimo a ser más productiva y a ordenar mis prioridades con mayor claridad. También noto una mejor gestión del estrés en momentos de presión.",
    name: "María Aristeguieta",
    role: "Talent Processes Senior Specialist at Avature, Spain"
  },
  {
    quote: "¡Ojalá todos pudieran asistir a este workshop! Fue increíblemente valioso experimentar el mindfulness y llevarnos herramientas concretas para aplicar en el trabajo. Salimos con más presencia, mejor escucha y una energía de equipo mucho más conectada. ¡Tu workshop es oro puro!",
    name: "Vanessa Fernández",
    role: "Senior Product Manager at Giftify, Belgium"
  },
  {
    quote: "Gracias, Maria, por enseñarme que la pausa también es parte del proceso. Tu workshop me recordó que regularnos no es frenar, sino crear espacio para decidir mejor y colaborar con más empatía. Es una experiencia que realmente transforma la forma de vivir el día a día laboral.",
    name: "Stella Camacho",
    role: "Founder & Chief Creative Officer at Amorchi House"
  }
];

const closingQuote = (workshop as any)?.closingQuote ?? "El verdadero reto de la condición humana no es estar presente, sino darnos cuenta de que no estamos presentes.";
const closingQuoteAuthor = (workshop as any)?.closingQuoteAuthor ?? "Meggan Watterson";

const ctaTitle = workshop?.ctaTitle ?? "¿Quieres llevar esta experiencia a tu organización?";
const ctaButtonText = workshop?.ctaButtonText ?? "Solicitar propuesta";
const ctaButtonLink = (workshop as any)?.ctaButtonLink ?? "/contacto";
const heroSecondaryCtaText = (workshop as any)?.heroSecondaryCtaText ?? "Ver experiencia";
const heroSecondaryCtaLink = (workshop as any)?.heroSecondaryCtaLink ?? "#experiencia";

const workshopFacts = (workshop as any)?.facts?.length ? (workshop as any).facts : [
  { label: "Formato", value: "Team building", detail: "aprox. 12 personas" },
  { label: "Duración", value: "3 horas", detail: "sesión intensiva" },
  { label: "Modalidad", value: "Presencial", detail: "en tu empresa" }
];
const factsAriaLabel = (workshop as any)?.factsAriaLabel ?? "Datos del workshop";
const guideSloganAriaLabel = (workshop as any)?.guideSloganAriaLabel ?? "Slogan";
const aboutFactsAriaLabel = (workshop as any)?.aboutFactsAriaLabel ?? "Detalles del workshop";
const benefitsAriaLabel = (workshop as any)?.benefitsAriaLabel ?? "Beneficios para la empresa";
const quoteAriaLabel = (workshop as any)?.quoteAriaLabel ?? "Cita de cierre";
---

<Layout
  title={(workshop as any)?.seoTitle ?? "Workshop Mindfulness para Empresas | Pienso, luego medito | Eleahora"}
  description={(workshop as any)?.seoDescription ?? "Workshop experiencial de mindfulness y meditación para equipos. 'Pienso, luego medito' de Eleahora: 3h presenciales en tu empresa, herramientas de regulación del estrés y mejora del bienestar colectivo."}
  ogTitle={(workshop as any)?.ogTitle ?? "Workshop para Empresas — Pienso, luego medito | Eleahora"}
  ogImage={(workshop as any)?.ogImage ?? "https://eleahora.com/images/home-eleahora-002.webp"}
>
  <main class="workshop-page">

    <!-- ─── HERO ─────────────────────────────────────────── -->
    <section class="workshop-hero" aria-labelledby="workshop-title">
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="hero-orbits" aria-hidden="true">
        <span class="orbit orbit-a"></span>
        <span class="orbit orbit-b"></span>
        <span class="orbit orbit-c"></span>
      </div>

      <div class="max-w-screen hero-grid">
        <figure class="hero-media" aria-hidden="true">
          <div class="hero-media-grid">
            <div class="hero-image-card hero-image-card-primary">
              <img
                src={heroImage}
                alt={heroImageAlt}
                width="720"
                height="960"
                decoding="async"
                fetchpriority="high"
              />
            </div>
            <div class="hero-image-card hero-image-card-secondary">
              <img
                src={heroImage2}
                alt={heroImage2Alt}
                width="720"
                height="960"
                loading="eager"
                decoding="async"
              />
            </div>
          </div>
        </figure>

        <div class="hero-content">
          <div class="hero-top">
            <span class="hero-tag">{heroLabel}</span>
          </div>

          <h1 id="workshop-title">
            <em class="hero-em">{heroTitleFirst}</em>
            <span class="hero-line2">{heroTitleRest}</span>
          </h1>

          <p class="hero-subtitle">{heroSubtitle}</p>

          <div class="hero-cta-row">
            <a href={ctaButtonLink} class="btn-primary">{ctaButtonText}</a>
            <a href={heroSecondaryCtaLink} class="btn-outline">{heroSecondaryCtaText}</a>
          </div>

          <ul class="hero-facts" aria-label={factsAriaLabel}>
            {workshopFacts.map((fact: { label: string; value: string; detail: string }) => (
              <li class="fact-chip">
                <span class="fact-label">{fact.label}</span>
                <strong class="fact-value">{fact.value}</strong>
                <span class="fact-detail">{fact.detail}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- ─── SOBRE LA GUÍA ─────────────────────────────────── -->
    <section class="section-guide" aria-labelledby="guide-title">
      <div class="max-w-screen guide-grid">
        <div class="guide-text">
          <span class="eyebrow">{(workshop as any)?.guideEyebrow ?? "Sobre la Guía"}</span>
          <h2 id="guide-title">{guideName}</h2>
          <p>{guideBio}</p>
        </div>
        <figure class="guide-quote-block" aria-label={guideSloganAriaLabel}>
          <blockquote class="guide-slogan">
            <span class="slogan-accent">{guideSloganAccent}</span>
            <span class="slogan-main">{guideSloganMain}</span>
          </blockquote>
        </figure>
      </div>
    </section>

    <!-- ─── EL WORKSHOP ───────────────────────────────────── -->
    <section class="section-about" aria-labelledby="about-title">
      <div class="max-w-screen about-grid">
        <header class="about-header">
          <span class="eyebrow">{(workshop as any)?.workshopEyebrow ?? "El Workshop"}</span>
          <h2 id="about-title">{workshopTitle}</h2>
        </header>
        <div class="about-body">
          {workshopDescription.split('\n\n').filter(Boolean).map((p: string) => <p class="about-intro">{p}</p>)}
          <div class="about-facts-row" aria-label={aboutFactsAriaLabel}>
            {workshopFacts.map((fact: { label: string; value: string; detail: string }) => (
              <div class="about-fact">
                <span>{fact.label}</span>
                <strong>{fact.value}</strong>
                <em>{fact.detail}</em>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ─── EXPERIENCIA ───────────────────────────────────── -->
    <section class="section-experience" id="experiencia" aria-labelledby="exp-title">
      <div class="max-w-screen">
        <header class="section-header">
          <span class="eyebrow">{(workshop as any)?.experienceEyebrow ?? "¿Qué incluye la experiencia?"}</span>
          <h2 id="exp-title">{experienceTitle}</h2>
        </header>

        <ol class="experience-list">
          {experienceItems.map((item: any, index: number) => (
            <li class="exp-item">
              <span class="exp-num">{String(index + 1).padStart(2, "0")}</span>
              <div class="exp-content">
                <h3>{typeof item === 'string' ? item : item.title}</h3>
                <p>{typeof item === 'string' ? '' : item.description}</p>
              </div>
              <div class="exp-line" aria-hidden="true"></div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- ─── BENEFICIOS ────────────────────────────────────── -->
    <section class="section-benefits" aria-labelledby="benefits-title">
      <div class="max-w-screen benefits-inner">
        <header class="benefits-header">
          <span class="eyebrow">{(workshop as any)?.benefitsEyebrow ?? "¿Qué te llevas como empresa?"}</span>
          <h2 id="benefits-title">{benefitsTitle}</h2>
        </header>

        <ul class="benefits-cards" aria-label={benefitsAriaLabel}>
          {companyBenefits.map((benefit: any, i: number) => (
            <li class={`benefit-card benefit-card--${benefit.color || ['earth', 'sage', 'purple', 'red'][i % 4]}`}>
              <span class="benefit-dot" aria-hidden="true"></span>
              <p>{benefit.text || benefit.description}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ─── TESTIMONIOS ───────────────────────────────────── -->
    <section class="section-testimonials" aria-labelledby="test-title">
      <div class="max-w-screen">
        <header class="section-header">
          <span class="eyebrow">{testimonialsEyebrow}</span>
          <h2 id="test-title">{testimonialsTitle}</h2>
        </header>

        <div class="testimonials-grid">
          {testimonials.map((t: any, i: number) => (
            <blockquote class={`testimonial ${i === 0 ? 'testimonial--featured' : ''} testimonial--${t.color || ['vinotinto', 'verde', 'morado'][i % 3]}`}>
              <div class="testimonial-quote-mark" aria-hidden="true">"</div>
              <p class="testimonial-text">{t.quote}</p>
              {(t.author || t.name || t.role) && (
                <footer class="testimonial-footer">
                  <strong class="testimonial-author">{t.author || t.name}</strong>
                  {t.role && <span class="testimonial-role">{t.role}</span>}
                </footer>
              )}
            </blockquote>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── CITA DE CIERRE ───────────────────────────────────── -->
    <section class="section-quote" aria-label={quoteAriaLabel}>
      <div class="max-w-screen quote-inner">
        <blockquote class="closing-quote">
          "{closingQuote}"
          <cite>— {closingQuoteAuthor}</cite>
        </blockquote>
      </div>
    </section>

    <!-- ─── CTA ───────────────────────────────────────────── -->
    <section class="section-cta section-soft" aria-labelledby="cta-title">
      <div class="max-w-screen cta-inner">
        <img src="/images/textos/Siguiente-paso.png" alt="Siguiente paso" class="text-image" />
        <h2 id="cta-title">{ctaTitle}</h2>
        <div class="cta-actions">
          <a href="https://scheduler.zoom.us/maria-eleonora-051exv/30-min-con-eleahora" class="btn-primary" target="_blank" rel="noopener noreferrer">Agendar llamada de descubrimiento</a>
          <a href={ctaButtonLink} class="btn-outline">{ctaButtonText}</a>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  /* ═══════════════════════════════════════════
     PAGE BASE
  ═══════════════════════════════════════════ */
  .workshop-page {
    padding-top: 6rem;
    overflow-x: hidden;
  }

  /* ═══════════════════════════════════════════
     HERO
  ═══════════════════════════════════════════ */
  .workshop-hero {
    position: relative;
    padding: 8rem 0 6rem;
    isolation: isolate;
    overflow: hidden;
    background:
      radial-gradient(ellipse 80% 60% at 60% -10%, rgba(109, 68, 146, 0.18) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at -5% 80%, rgba(187, 137, 107, 0.14) 0%, transparent 55%),
      var(--color-background);
  }

  .hero-glow {
    position: absolute;
    top: -80px;
    left: 50%;
    transform: translateX(-50%);
    width: 900px;
    height: 500px;
    border-radius: 999px;
    background: radial-gradient(
      ellipse at center,
      rgba(109, 68, 146, 0.12) 0%,
      rgba(187, 137, 107, 0.08) 40%,
      transparent 70%
    );
    filter: blur(60px);
    pointer-events: none;
    z-index: -1;
    animation: heroGlowFloat 10s ease-in-out infinite;
  }

  .hero-orbits {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: -1;
    overflow: hidden;
  }

  .orbit {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(59, 38, 57, 0.07);
  }

  .orbit-a {
    width: 900px;
    height: 900px;
    top: -320px;
    right: -200px;
    border-color: rgba(109, 68, 146, 0.1);
    animation: orbitDriftA 16s ease-in-out infinite;
  }

  .orbit-b {
    width: 600px;
    height: 600px;
    bottom: -250px;
    left: -150px;
    border-color: rgba(187, 137, 107, 0.12);
    animation: orbitDriftB 14s ease-in-out infinite;
  }

  .orbit-c {
    width: 320px;
    height: 320px;
    top: 40px;
    left: 38%;
    border-color: rgba(140, 7, 3, 0.1);
    animation: orbitDriftC 12s ease-in-out infinite;
  }

  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    grid-template-areas: "content media";
    gap: 2.5rem;
    align-items: center;
  }

  .hero-content {
    grid-area: content;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    padding: 2.4rem 2.1rem;
    border-radius: 26px;
    z-index: 1;
  }

  .hero-content::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: inherit;
    background:
      linear-gradient(110deg, rgba(253, 251, 236, 0.86) 0%, rgba(253, 251, 236, 0.72) 48%, rgba(253, 251, 236, 0.52) 100%),
      radial-gradient(ellipse 120% 95% at 20% 15%, rgba(253, 251, 236, 0.5) 0%, transparent 66%);
    box-shadow:
      0 20px 50px rgba(59, 38, 57, 0.11),
      inset 0 1px 0 rgba(255, 255, 255, 0.78);
    backdrop-filter: blur(3px);
  }

  .hero-media {
    grid-area: media;
    margin: 0;
  }

  .hero-media-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    position: relative;
  }

  .hero-image-card {
    --card-rotate: 0deg;
    --card-offset-y: 0px;
    border-radius: 22px;
    overflow: hidden;
    border: 1px solid rgba(59, 38, 57, 0.12);
    box-shadow:
      0 20px 46px rgba(59, 38, 57, 0.14),
      inset 0 1px 0 rgba(255, 255, 255, 0.5);
    background: rgba(255, 255, 255, 0.48);
    transform-origin: center;
    transform: translateY(var(--card-offset-y)) rotate(var(--card-rotate)) scale(1);
    transition: transform 0.35s ease, box-shadow 0.35s ease;
    opacity: 0;
    animation: heroImageEnter 0.8s cubic-bezier(0.19, 1, 0.22, 1) forwards;
    will-change: transform, opacity;
  }

  .hero-image-card:hover {
    transform: translateY(var(--card-offset-y)) rotate(var(--card-rotate)) scale(1.04);
    box-shadow:
      0 28px 60px rgba(59, 38, 57, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.62);
  }

  .hero-image-card img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 16 / 10;
  }

  .hero-image-card-primary {
    --card-rotate: -1.2deg;
    animation-delay: 70ms;
  }

  .hero-image-card-secondary {
    max-width: 82%;
    justify-self: end;
    --card-offset-y: -12%;
    --card-rotate: 2deg;
    animation-delay: 150ms;
  }

  @keyframes heroImageEnter {
    0% {
      opacity: 0;
      transform: translateY(calc(var(--card-offset-y) + 22px)) rotate(calc(var(--card-rotate) - 1deg)) scale(0.9);
    }
    100% {
      opacity: 1;
      transform: translateY(var(--card-offset-y)) rotate(var(--card-rotate)) scale(1);
    }
  }

  @keyframes heroGlowFloat {
    0%,
    100% {
      transform: translateX(-50%) translateY(0);
      opacity: 0.95;
    }
    50% {
      transform: translateX(-50%) translateY(14px);
      opacity: 0.75;
    }
  }

  @keyframes orbitDriftA {
    0%,
    100% {
      transform: translate3d(0, 0, 0);
    }
    50% {
      transform: translate3d(-16px, 10px, 0);
    }
  }

  @keyframes orbitDriftB {
    0%,
    100% {
      transform: translate3d(0, 0, 0);
    }
    50% {
      transform: translate3d(14px, -12px, 0);
    }
  }

  @keyframes orbitDriftC {
    0%,
    100% {
      transform: translate3d(0, 0, 0);
    }
    50% {
      transform: translate3d(-10px, 8px, 0);
    }
  }

  .hero-top {
    margin-bottom: 2rem;
  }

  .hero-tag {
    display: inline-block;
    padding: 0.4rem 1.1rem;
    border-radius: 999px;
    border: 1px solid rgba(59, 38, 57, 0.18);
    background: rgba(255, 255, 255, 0.55);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(59, 38, 57, 0.75);
    font-family: var(--font-base);
    backdrop-filter: blur(8px);
  }

  .workshop-hero h1 {
    margin: 0 0 1.15rem;
    line-height: 0.96;
    letter-spacing: -0.028em;
  }

  .hero-em {
    display: block;
    font-family: var(--font-primary);
    font-style: normal;
    color: var(--color-accent-red);
    font-size: clamp(2.2rem, 5.6vw, 4.8rem);
    line-height: 0.95;
  }

  .hero-line2 {
    display: block;
    font-family: var(--font-primary);
    font-size: clamp(2.2rem, 5.4vw, 4.8rem);
    color: var(--color-primary-dark);
    line-height: 1;
  }

  .hero-subtitle {
    font-size: clamp(1.02rem, 1.5vw, 1.28rem);
    line-height: 1.55;
    color: rgba(59, 38, 57, 0.78);
    max-width: 34ch;
    margin-bottom: 2.1rem;
    opacity: 1;
  }

  .hero-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 3.5rem;
  }

  .hero-facts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .fact-chip {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 1.1rem 1.5rem;
    border-radius: 20px;
    border: 1px solid rgba(59, 38, 57, 0.1);
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(14px);
    box-shadow:
      0 8px 24px rgba(59, 38, 57, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
    min-width: 160px;
  }

  .fact-label {
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(59, 38, 57, 0.5);
    font-family: var(--font-base);
  }

  .fact-value {
    font-family: var(--font-primary);
    font-size: 1.25rem;
    color: var(--color-primary-dark);
