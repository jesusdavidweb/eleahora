---
import Layout from '../layouts/Layout.astro';
import { getWorkshopPage, getSiteConfig } from '../lib/keystatic';

const workshop = await getWorkshopPage();
const site     = await getSiteConfig();

const heroLabel    = workshop?.heroLabel    ?? 'Workshop para empresas';
const heroTitle    = workshop?.heroTitle    ?? 'Pienso, luego medito.';
const heroSubtitle = workshop?.heroSubtitle ?? 'Una experiencia de mindfulness y meditación diseñada para equipos y organizaciones.';
const heroImage    = workshop?.heroImage    ?? null;
const introTitle   = workshop?.introTitle   ?? null;
const benefitsTitle = workshop?.benefitsTitle ?? '¿Qué se llevan los equipos?';
const benefits      = workshop?.benefits     ?? [
  { title: 'Regulación del sistema nervioso', description: 'Herramientas prácticas para gestionar el estrés en el entorno laboral.' },
  { title: 'Mejora del foco y la concentración', description: 'Técnicas de atención plena aplicadas al rendimiento profesional.' },
  { title: 'Cohesión de equipo', description: 'Una experiencia compartida que fortalece los vínculos y la comunicación.' },
  { title: 'Reducción del absentismo', description: 'El bienestar emocional es una inversión que impacta directamente en la productividad y la retención del talento.' },
];
const formatsTitle = workshop?.formatsTitle ?? 'Formatos disponibles';
const formats      = workshop?.formats      ?? [
  { name: 'Sesión única', duration: '90 min', description: 'Introducción al mindfulness con práctica guiada. Ideal para eventos o team days.' },
  { name: 'Taller de medio día', duration: '3-4 horas', description: 'Teoría + práctica + meditaciones guiadas. Incluye material de apoyo.' },
  { name: 'Programa mensual', duration: '4 sesiones', description: 'Un mes de acompañamiento con sesiones semanales para consolidar el hábito.' },
];
const ctaTitle      = workshop?.ctaTitle      ?? '¿Hablamos para tu empresa?';
const ctaBody       = workshop?.ctaBody       ?? 'Cuéntame el tamaño de tu equipo y qué necesitáis, y diseñamos juntos la experiencia perfecta.';
const ctaButtonText = workshop?.ctaButtonText ?? 'Solicitar información';

const whatsapp = site?.phoneWhatsapp ?? '+34605373782';
const waLink   = `https://wa.me/${whatsapp.replace(/\D/g, '')}`;
---

<Layout
  title="Workshop 'Pienso, luego medito' | Mindfulness para Empresas | Eleahora"
  description="Workshop de mindfulness y meditación para empresas y equipos. Programa 'Pienso, luego medito' de Eleahora: reduce el estrés, mejora el foco y fortalece la cohesión del equipo."
  ogTitle="Workshop para Empresas — Eleahora"
  ogImage="/images/OG-images-eleahora-01.jpg"
>
  <main class="workshop-page">

    <!-- Hero -->
    <section class="workshop-hero">
      {heroImage && (
        <img src={heroImage} alt={heroTitle} class="workshop-hero-bg" />
      )}
      <div class="workshop-hero-overlay"></div>
      <div class="max-w-screen workshop-hero-content">
        <span class="workshop-kicker">{heroLabel}</span>
        <h1>{heroTitle}</h1>
        <p class="workshop-hero-sub">{heroSubtitle}</p>
        <div class="workshop-hero-ctas">
          <a href={waLink} target="_blank" rel="noopener noreferrer" class="btn-primary workshop-cta-btn">{ctaButtonText}</a>
          <a href="/contacto" class="btn-outline workshop-cta-btn">¿Tienes preguntas?</a>
        </div>
      </div>
    </section>

    <!-- Intro (si existe en Keystatic) -->
    {introTitle && (
      <section class="workshop-intro">
        <div class="max-w-screen">
          <h2>{introTitle}</h2>
          {workshop?.introBody && (
            (workshop.introBody as any[]).map((block: any) => (
              block.type === 'paragraph' && (
                <p>{block.children?.map((c: any) => c.text).join('')}</p>
              )
            ))
          )}
        </div>
      </section>
    )}

    <!-- Beneficios -->
    <section class="workshop-benefits">
      <div class="max-w-screen">
        <h2 class="section-title">{benefitsTitle}</h2>
        <div class="benefits-grid">
          {benefits.map((b) => (
            <div class="benefit-card">
              <h3>{b.title}</h3>
              <p>{b.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Formatos -->
    <section class="workshop-formats">
      <div class="max-w-screen">
        <h2 class="section-title">{formatsTitle}</h2>
        <div class="formats-grid">
          {formats.map((f) => (
            <div class="format-card">
              <span class="format-duration">{f.duration}</span>
              <h3>{f.name}</h3>
              <p>{f.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA final -->
    <section class="workshop-cta-section">
      <div class="max-w-screen workshop-cta-inner">
        <h2>{ctaTitle}</h2>
        <p>{ctaBody}</p>
        <div class="workshop-hero-ctas">
          <a href={waLink} target="_blank" rel="noopener noreferrer" class="btn-primary">{ctaButtonText}</a>
          <a href="/contacto" class="btn-outline">Formulario de contacto</a>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  .workshop-page { padding-top: 6rem; }

  /* Hero */
  .workshop-hero { position: relative; min-height: 80vh; display: flex; align-items: center; overflow: hidden; background-color: var(--color-primary-dark); }
  .workshop-hero-bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center; opacity: 0.5; }
  .workshop-hero-overlay { position: absolute; inset: 0; background: linear-gradient(to right, rgba(59,38,57,0.85) 0%, rgba(59,38,57,0.6) 40%, rgba(59,38,57,0.3) 100%); }
  .workshop-hero-content { position: relative; z-index: 1; padding: 6rem 0; max-width: 700px; }
  .workshop-kicker { display: block; font-family: var(--font-primary); color: var(--color-earth); font-size: clamp(1.4rem, 2.5vw, 2rem); text-transform: lowercase; margin-bottom: 1rem; }
  .workshop-kicker::first-letter { font-family: var(--font-accent); text-transform: uppercase; font-size: 1.5em; }
  .workshop-hero h1 { font-size: clamp(3rem, 6vw, 5.5rem); color: var(--color-background); line-height: 1.05; margin-bottom: 1.5rem; letter-spacing: -0.02em; }
  .workshop-hero-sub { font-size: clamp(1.1rem, 2vw, 1.35rem); color: rgba(253,251,236,0.85); line-height: 1.65; max-width: 50ch; margin-bottom: 2.5rem; }
  .workshop-hero-ctas { display: flex; flex-wrap: wrap; gap: 1rem; }
  .workshop-cta-btn { min-width: 220px; justify-content: center; }

  /* Intro */
  .workshop-intro { padding: 6rem 0; background-color: var(--color-background); }
  .workshop-intro h2 { font-size: clamp(2rem, 4vw, 3.5rem); margin-bottom: 1.5rem; color: var(--color-primary-dark); }
  .workshop-intro p { font-size: 1.15rem; line-height: 1.8; max-width: 70ch; opacity: 0.85; margin-bottom: 1.2rem; }

  /* Beneficios */
  .workshop-benefits { padding: 7rem 0; background: linear-gradient(135deg, rgba(59,38,57,0.04) 0%, rgba(109,68,146,0.06) 100%); }
  .section-title { font-size: clamp(2rem, 4vw, 3.5rem); color: var(--color-primary-dark); margin-bottom: 3rem; }
  .benefits-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.5rem; }
  .benefit-card { padding: 2.5rem; background: #fff; border-radius: 20px; border: 1px solid rgba(59,38,57,0.08); box-shadow: 0 8px 24px rgba(59,38,57,0.06); transition: transform 0.3s ease; }
  .benefit-card:hover { transform: translateY(-4px); }
  .benefit-card h3 { font-size: 1.35rem; color: var(--color-primary-dark); margin-bottom: 0.75rem; }
  .benefit-card p { font-size: 1rem; line-height: 1.7; opacity: 0.8; margin: 0; }

  /* Formatos */
  .workshop-formats { padding: 7rem 0; background-color: var(--color-primary-dark); }
  .workshop-formats .section-title { color: var(--color-background); }
  .formats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; }
  .format-card { padding: 2.5rem; border: 1px solid rgba(253,251,236,0.12); border-radius: 20px; background: rgba(255,255,255,0.04); transition: background 0.3s ease; }
  .format-card:hover { background: rgba(255,255,255,0.08); }
  .format-duration { display: inline-block; font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-earth); border: 1px solid rgba(187,137,107,0.3); border-radius: 999px; padding: 0.3rem 0.8rem; margin-bottom: 1rem; }
  .format-card h3 { font-size: 1.5rem; color: var(--color-background); margin-bottom: 0.75rem; }
  .format-card p { font-size: 1rem; line-height: 1.7; color: rgba(253,251,236,0.7); margin: 0; }

  /* CTA final */
  .workshop-cta-section { padding: 8rem 0; background-color: var(--color-accent-red); }
  .workshop-cta-inner { text-align: center; max-width: 720px; }
  .workshop-cta-inner h2 { font-size: clamp(2.2rem, 4vw, 3.5rem); color: var(--color-background); margin-bottom: 1.5rem; }
  .workshop-cta-inner p { font-size: 1.15rem; color: rgba(253,251,236,0.85); line-height: 1.7; margin-bottom: 2.5rem; }
  .workshop-cta-section .btn-primary { background-color: var(--color-background); color: var(--color-primary-dark); border-color: var(--color-background); }
  .workshop-cta-section .btn-primary:hover { background-color: transparent; color: var(--color-background); }
  .workshop-cta-section .btn-outline { color: var(--color-background); border-color: rgba(253,251,236,0.4); }
  .workshop-cta-section .btn-outline:hover { background-color: var(--color-background); color: var(--color-primary-dark); }

  @media (max-width: 768px) {
    .workshop-page { padding-top: 5.25rem; }
    .workshop-hero { min-height: 60vh; }
    .workshop-hero-content { padding: 4rem 0; }
    .workshop-hero-ctas { flex-direction: column; }
    .workshop-cta-btn { min-width: unset; width: 100%; }
    .workshop-cta-inner { text-align: left; }
    .workshop-cta-section .workshop-hero-ctas { flex-direction: column; }
  }
</style>
