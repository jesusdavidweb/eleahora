---
import Layout from "../layouts/Layout.astro";
import { getSessionesPage, getAllSesiones, getSiteConfig } from "../lib/keystatic";

// Keystatic: datos del CMS con fallback a contenido actual
const sesionesPage = await getSessionesPage();
const sesiones = await getAllSesiones();
const siteConfig = await getSiteConfig();

// Fallbacks para la cabecera
const heroLabel = sesionesPage?.heroLabel ?? "Sesiones";
const heroTitle = sesionesPage?.heroTitle ?? "¿Con cuál te gustaría empezar?";
const heroSubtitle = sesionesPage?.heroSubtitle ?? "Permítete leer cada una con calma y déjate sentir.";
const heroImage = sesionesPage?.heroImage ?? "/images/home-mindfulness-01-tiny.webp";
const ctaTitle = sesionesPage?.ctaTitle ?? "Si aún no lo tienes claro, escríbeme aquí";
const ctaLink = (sesionesPage as any)?.ctaLink ?? "/contacto";
const bookingUrl = siteConfig?.calLink ?? "https://scheduler.zoom.us/maria-eleonora-051exv/sesi-n-eleahora";

// Mapeo de modalidad
function getModalityLabel(modality: string): string {
  switch (modality) {
    case 'online': return 'Videollamada';
    case 'presencial': return 'Presencial en Madrid';
    case 'ambas': return 'Videollamada o Presencial en Madrid';
    default: return modality;
  }
}

// Datos de sesiones: usar Keystatic o fallback hardcodeado
const sesionesData = sesiones.length > 0 ? sesiones : null;
---

<Layout
  title="Sesiones | Terapia Transpersonal y Meditación | Eleahora"
  description="Descubre las sesiones de Eleahora: Acompañamiento Terapéutico con PNL, Terapia Angelical, Perlas de Eleahora, Clase de Meditación y Sesión Energética. Presencial en Madrid y online."
  ogTitle="Sesiones — Eleahora"
  ogImage="/images/OG-images-eleahora-01.jpg"
>
  <main class="services-page">
    <section class="services-hero">
      <div class="max-w-screen hero-container">
        <div class="hero-media">
          <img src={heroImage} alt="" loading="eager" decoding="async" />
        </div>
        <div class="hero-content">
          <span class="text-accent section-label">{heroLabel}</span>
          <h1>{heroTitle}</h1>
          <p>
            {heroSubtitle}
          </p>
        </div>
      </div>
    </section>

    <section class="services-list">
      <div class="max-w-screen list-wrap">
        {sesionesData ? (
          sesionesData.map((s, i) => (
            <article class={`service-item ${i === 0 ? 'service-item-featured' : ''}`}>
              <div class="service-top">
                <span class="service-number">{String(i + 1).padStart(2, '0')}</span>
                {s.entry.tagline && <span class="service-pill">{s.entry.tagline}</span>}
              </div>
              <h2>{s.entry.title}</h2>
              <div set:html={s.entry.descriptionHtml} />
              <ul>
                {(s.entry as any)?.sessions && <li><strong>Sesiones:</strong> {(s.entry as any).sessions}</li>}
                {s.entry.duration && <li><strong>Duración:</strong> {s.entry.duration}</li>}
                <li><strong>Modalidad:</strong> {getModalityLabel(s.entry.modality)}</li>
                {s.entry.price && <li><strong>Intercambio:</strong> {s.entry.price}</li>}
              </ul>
              {(s.entry as any)?.includesPlan && (
                <div class="service-meta">
                  <span>{(s.entry as any).includesPlan}</span>
                </div>
              )}
              <a href={s.entry.bookingUrl || bookingUrl} class="btn-primary service-cta">{(s.entry as any)?.ctaText || 'Reservar ahora'}</a>
            </article>
          ))
        ) : (
          <>
        <article class="service-item service-item-featured">
          <div class="service-top">
            <span class="service-number">01</span>
            <span class="service-pill">Proceso profundo</span>
          </div>
          <h2>Acompañamiento Terapéutico (Meditación + PNL)</h2>
          <p>
            Este acompañamiento nace para sostenerte en los procesos que estás
            atravesando, especialmente cuando necesitas claridad, calma y una nueva
            manera de habitar lo que estás viviendo.
          </p>
          <ul>
            <li>
              <strong>¿En qué consiste?</strong> Combinamos conversación terapéutica,
              meditación guiada y técnicas de PNL para revisar tu diálogo interno y
              permitir que nuevas perspectivas emerjan en ti. Cada sesión es única.
              No hay fórmulas rígidas, sino una escucha atenta y un acompañamiento
              presente, respetuoso y humano.
            </li>
            <li><strong>Sesiones:</strong> 4 (acompañamiento mensual)</li>
            <li><strong>Duración:</strong> 1h cada sesión</li>
            <li><strong>Modalidad:</strong> Videollamada</li>
            <li><strong>Intercambio mensual:</strong> 180€</li>
          </ul>
          <div class="service-meta">
            <span>Incluye plan de integración</span>
            <span>Acompañamiento mensual</span>
          </div>
          <a href={bookingUrl} class="btn-primary service-cta">Agendar llamada de descubrimiento (30min)</a>
        </article>

        <article class="service-item">
          <div class="service-top">
            <span class="service-number">02</span>
            <span class="service-pill">Canalización</span>
          </div>
          <h2>Terapia Angelical</h2>
          <p>
            Sesión de conexión con tus ángeles y seres de luz. Iniciamos con una
            meditación de sanación para elevar tu vibración. Luego canalizamos sus
            mensajes a través de oráculos angelicales, donde podrás hacer entre 6 y
            8 preguntas para recibir guía y claridad.
          </p>
          <ul>
            <li><strong>Sesiones:</strong> 1</li>
            <li><strong>Duración:</strong> 1h - 1h30 máx</li>
            <li><strong>Modalidad:</strong> Videollamada o Presencial en Madrid</li>
            <li><strong>Intercambio:</strong> 55€</li>
          </ul>
          <div class="service-meta">
            <span>Sanación + mensaje</span>
            <span>Oráculos especiales</span>
          </div>
          <a href={bookingUrl} class="btn-primary service-cta">Agendar Terapia</a>
        </article>

        <article class="service-item">
          <div class="service-top">
            <span class="service-number">03</span>
            <span class="service-pill">Canal íntimo</span>
          </div>
          <h2>Perlas de Eleahora</h2>
          <p>
            Sesión íntima, canalizada y reveladora. A través de una metodología
            única que combina preguntas poderosas, oráculos y dinámicas de escritura
            consciente, iremos explorando los temas que hoy tienes "sobre la mesa".
          </p>
          <p>
            Es un espacio que une coaching y espiritualidad. Trabajamos con la voz
            de tu niñ@ interior, tu sabiduría y tu visión hacia lo que quieres.
          </p>
          <p>
            Ideal para vaciar la mente, poner orden en lo interno y salir con más
            dirección.
          </p>
          <ul>
            <li><strong>Sesiones:</strong> 1</li>
            <li><strong>Duración:</strong> 1h - 1h30 máx</li>
            <li><strong>Modalidad:</strong> Presencial en Madrid</li>
            <li><strong>Intercambio:</strong> 70€</li>
          </ul>
          <div class="service-meta">
            <span>Exploración emocional</span>
            <span>Escritura consciente</span>
          </div>
          <a href={bookingUrl} class="btn-primary service-cta">Quiero mis perlas</a>
        </article>

        <article class="service-item">
          <div class="service-top">
            <span class="service-number">04</span>
            <span class="service-pill">Base práctica</span>
          </div>
          <h2>Clase de Meditación</h2>
          <p>
            Clase teórico-práctica para comprender cómo funciona tu sistema nervioso
            y cómo regularlo puede ayudarte a volver al presente.
          </p>
          <p>
            Aprenderás herramientas concretas de neurorregulación que podrás aplicar
            en tu día a día, y terminaremos con una meditación guiada que te
            permitirá experimentar la diferencia entre cómo llegaste y cómo te vas.
          </p>
          <p>
            Mi intención con esta sesión es que te lleves la práctica y lo aprendido
            a tu cotidianidad.
          </p>
          <ul>
            <li><strong>Sesiones:</strong> 1</li>
            <li><strong>Duración:</strong> 1h - 1h30 máx</li>
            <li><strong>Modalidad:</strong> Videollamada</li>
            <li><strong>Intercambio:</strong> 40€</li>
          </ul>
          <div class="service-meta">
            <span>Enfoque mente-cuerpo</span>
            <span>Herramientas aplicables</span>
          </div>
          <a href={bookingUrl} class="btn-primary service-cta">Quiero aprender a meditar</a>
        </article>

        <article class="service-item">
          <div class="service-top">
            <span class="service-number">05</span>
            <span class="service-pill">Reset energético</span>
          </div>
          <h2>Sesión Energética (Chakras)</h2>
          <p>
            Revisaremos cómo se encuentran tus 7 centros energéticos, identificando
            cuáles necesitan más atención y nos centraremos en limpiarlos, alinearlos
            y activarlos. Me gusta definir esta sesión como un "reset energético".
          </p>
          <p>
            Es una de las herramientas más bonitas de autocuidado: un espacio para
            armonizar y revitalizar tu energía.
          </p>
          <ul>
            <li><strong>Sesiones:</strong> 1</li>
            <li><strong>Duración:</strong> 1h30</li>
            <li><strong>Modalidad:</strong> Videollamada o Presencial en Madrid</li>
            <li><strong>Intercambio:</strong> 65€</li>
          </ul>
          <div class="service-meta">
            <span>Armonización de chakras</span>
            <span>Impulso de energía vital</span>
          </div>
          <a href={bookingUrl} class="btn-primary service-cta">Agendar Sesión</a>
        </article>
          </>
        )}
      </div>
    </section>

    <section class="services-final-cta" aria-label="Ayuda para elegir sesión">
      <div class="max-w-screen final-cta-wrap">
        <p>{ctaTitle}</p>
        <a href={ctaLink} class="btn-primary">Contactar para más información</a>
      </div>
    </section>
  </main>
</Layout>

<style>
  .services-page {
    padding-top: 6rem;
  }

  .services-hero {
    padding: 7rem 0 4rem;
    background: linear-gradient(
      180deg,
      rgba(109, 68, 146, 0.12) 0%,
      rgba(253, 251, 236, 1) 75%
    );
  }

  .hero-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: center;
  }

  .hero-media {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-media img {
    width: 100%;
    max-width: 400px;
    height: auto;
    object-fit: contain;
    border-radius: 12px;
    box-shadow: 0 8px 24px rgba(59, 38, 57, 0.15);
  }

  .hero-content {
    max-width: 500px;
  }

  .section-label {
    display: block;
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    margin-bottom: 0.75rem;
    font-family: var(--font-primary);
    text-transform: lowercase;
  }

  .section-label::first-letter {
    font-family: var(--font-accent);
    text-transform: uppercase;
    font-size: 1.5em;
  }

  h1 {
    font-size: clamp(2.4rem, 5vw, 4.5rem);
    margin-bottom: 1.2rem;
  }

  .hero-wrap p {
    max-width: 60ch;
    font-size: 1.2rem;
  }

  .services-list {
    padding: 2.5rem 0 6rem;
  }

  .services-final-cta {
    padding: 0 0 6rem;
  }

  .final-cta-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 2rem 1.5rem;
    border: 1px solid rgba(109, 68, 146, 0.24);
    border-radius: 22px;
    background:
      radial-gradient(circle at 10% 10%, rgba(109, 68, 146, 0.08), transparent 45%),
      radial-gradient(circle at 90% 90%, rgba(140, 7, 3, 0.08), transparent 42%),
      rgba(255, 255, 255, 0.7);
    box-shadow:
      0 12px 26px rgba(59, 38, 57, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.85);
  }

  .final-cta-wrap p {
    margin: 0;
    font-size: 1.2rem;
    text-align: center;
    color: rgba(59, 38, 57, 0.9);
  }

  .list-wrap {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    grid-auto-flow: dense;
    align-items: stretch;
    gap: 1.6rem;
  }

  .service-item {
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(59, 38, 57, 0.1);
    border-radius: 22px;
    padding: 2rem;
    background:
      radial-gradient(circle at 92% -8%, rgba(109, 68, 146, 0.11), transparent 52%),
      radial-gradient(circle at 8% 108%, rgba(140, 7, 3, 0.08), transparent 50%),
      rgba(255, 255, 255, 0.8);
    box-shadow:
      0 16px 34px rgba(59, 38, 57, 0.07),
      inset 0 1px 0 rgba(255, 255, 255, 0.84);
    transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
    will-change: transform;
    min-height: 100%;
  }

  .service-item-featured {
    grid-column: span 2;
  }

  .service-item::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(130deg, transparent 30%, rgba(255, 255, 255, 0.35) 52%, transparent 75%);
    transform: translateX(-110%);
    transition: transform 0.7s ease;
    pointer-events: none;
  }

  .service-item:hover {
    transform: translateY(-7px);
    border-color: rgba(109, 68, 146, 0.2);
    box-shadow:
      0 20px 40px rgba(59, 38, 57, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.88);
  }

  .service-item:hover::after {
    transform: translateX(110%);
  }

  .service-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.1rem;
  }

  .service-number {
    font-family: var(--font-display, 'Pacaembu', sans-serif);
    font-size: 1.15rem;
    letter-spacing: 0.08em;
    color: var(--color-primary-dark);
    opacity: 0.56;
  }

  .service-pill {
    display: inline-flex;
    align-items: center;
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(59, 38, 57, 0.82);
    background: linear-gradient(
      120deg,
      rgba(59, 38, 57, 0.12),
      rgba(109, 68, 146, 0.12)
    );
    border: 1px solid rgba(109, 68, 146, 0.22);
    padding: 0.4rem 0.78rem;
    border-radius: 999px;
    box-shadow: 0 4px 12px rgba(59, 38, 57, 0.08);
  }

  .service-item h2 {
    font-size: clamp(1.45rem, 2.7vw, 2.2rem);
    line-height: 1.2;
    margin-bottom: 0.85rem;
  }

  .service-item p,
  .service-item li {
    font-size: 1.04rem;
    line-height: 1.72;
  }

  .service-item ul {
    margin: 1.05rem 0 1.4rem;
    padding-left: 1.15rem;
    color: rgba(59, 38, 57, 0.92);
  }

  .service-item li {
    margin-bottom: 0.46rem;
  }

  .service-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 0.35rem 0 1.2rem;
  }

  .service-meta span {
    display: inline-flex;
    align-items: center;
    font-size: 0.88rem;
    color: rgba(86, 100, 67, 0.82);
    border: 1px solid rgba(86, 100, 67, 0.18);
    background: rgba(86, 100, 67, 0.05);
    border-radius: 999px;
    padding: 0.34rem 0.7rem;
  }

  .service-cta {
    margin-top: auto;
    align-self: flex-start;
    box-shadow: 0 8px 16px rgba(140, 7, 3, 0.1);
  }

  @media (max-width: 1100px) {
    .service-item-featured {
      grid-column: span 1;
    }
  }

  @media (max-width: 768px) {
    .services-page {
      padding-top: 5.25rem;
    }

    .services-hero {
      padding: 5rem 0 3rem;
    }

    .hero-container {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .hero-media img {
      max-width: 300px;
    }

    .services-list {
      padding-top: 2rem;
    }

    .service-item {
      padding: 1.4rem;
      border-radius: 18px;
    }

    .service-pill {
      font-size: 0.75rem;
      letter-spacing: 0.05em;
    }

    .service-cta {
      width: 100%;
      text-align: center;
    }

    .final-cta-wrap {
      padding: 1.5rem 1rem;
      border-radius: 18px;
    }
  }
</style>
