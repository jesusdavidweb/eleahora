---
import Layout from '../layouts/Layout.astro';
import ThanksExperience from '../components/svelte/ThanksExperience.svelte';

const contactName = (Astro.url.searchParams.get('nombre') ?? '').trim();
const firstName = contactName ? contactName.split(/\s+/)[0] : '';
---

<Layout
  title="Gracias | Eleahora"
  description="Gracias por contactar con Eleahora. Hemos recibido tu mensaje y en breve recibirás una respuesta para comenzar tu proceso."
  ogTitle="Gracias por tu mensaje | Eleahora"
  noindex={true}
>
  <ThanksExperience client:load />

  <main class="thanks-page">
    <section class="thanks-hero" aria-labelledby="gracias-title">

      <!-- Ambient glow -->
      <div class="thanks-glow" aria-hidden="true"></div>

      <!-- Orbit rings -->
      <div class="thanks-orbits" aria-hidden="true">
        <span class="orbit orbit-a"></span>
        <span class="orbit orbit-b"></span>
        <span class="orbit orbit-c"></span>
      </div>

      <!-- Content — centrado horizontal y vertical -->
      <div class="thanks-content">
        <p class="thanks-kicker thanks-hero-animate">Mensaje recibido</p>
        <h1 id="gracias-title" class="thanks-hero-animate">
          {firstName ? `${firstName}, gracias por escribir a Eleahora.` : 'Gracias por escribir a Eleahora.'}
        </h1>
        <p class="thanks-lead thanks-hero-animate">
          Tu solicitud ya entró en la bandeja prioritaria. Te responderé en máximo 24&nbsp;horas laborables para coordinar el siguiente paso.
        </p>
        <div class="thanks-actions thanks-hero-animate">
          <a
            href="https://scheduler.zoom.us/maria-eleonora-051exv/sesi-n-eleahora"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary thanks-magnetic"
          >Reservar ahora</a>
          <a
            href="https://wa.me/34605373782"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-outline thanks-magnetic"
          >Escribir por WhatsApp</a>
        </div>
      </div>

    </section>
  </main>
</Layout>

<style>
  .thanks-page {
    background-color: var(--color-background);
  }

  /* ── Full-screen hero centrada ── */
  .thanks-hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    isolation: isolate;
    overflow: hidden;
    background:
      radial-gradient(ellipse at 20% 20%, rgba(109, 68, 146, 0.13) 0%, transparent 55%),
      radial-gradient(ellipse at 80% 30%, rgba(140, 7, 3, 0.09) 0%, transparent 50%),
      var(--color-background);
  }

  /* ── Glow central difuminado ── */
  .thanks-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 70vw;
    max-width: 900px;
    height: 60vh;
    border-radius: 999px;
    background: radial-gradient(
      ellipse,
      rgba(187, 137, 107, 0.13) 0%,
      rgba(109, 68, 146, 0.09) 40%,
      transparent 70%
    );
    filter: blur(72px);
    z-index: -1;
    pointer-events: none;
  }

  /* ── Órbitas ── */
  .thanks-orbits {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: -1;
  }

  .orbit {
    position: absolute;
    border-radius: 999px;
    border: 1px solid rgba(59, 38, 57, 0.08);
  }

  .orbit-a {
    width: min(80vw, 800px);
    height: min(80vw, 800px);
    top: 50%;
    left: 50%;
    transform: translate(-20%, -60%);
  }

  .orbit-b {
    width: min(60vw, 560px);
    height: min(60vw, 560px);
    top: 50%;
    left: 50%;
    transform: translate(-80%, -40%);
    border-color: rgba(86, 100, 67, 0.1);
  }

  .orbit-c {
    width: min(38vw, 320px);
    height: min(38vw, 320px);
    top: 50%;
    left: 50%;
    transform: translate(-40%, 10%);
    border-color: rgba(140, 7, 3, 0.07);
  }

  /* ── Contenido ── */
  .thanks-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 720px;
    padding: 0 1.5rem;
  }

  .thanks-kicker {
    display: block;
    font-family: var(--font-primary);
    color: var(--color-accent-red);
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1;
    margin-bottom: 1.25rem;
    text-transform: lowercase;
  }

  .thanks-kicker::first-letter {
    font-family: var(--font-accent);
    text-transform: uppercase;
    font-size: 1.5em;
  }

  h1 {
    font-size: clamp(2.4rem, 5.5vw, 4.5rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-weight: 500;
    margin-bottom: 1.5rem;
  }

  .thanks-lead {
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    line-height: 1.75;
    max-width: 46ch;
    margin: 0 auto 2.75rem;
    opacity: 0.8;
  }

  .thanks-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }

  /* ── Mobile ── */
  @media (max-width: 600px) {
    .thanks-actions .btn-primary,
    .thanks-actions .btn-outline {
      width: 100%;
    }
  }
</style>
