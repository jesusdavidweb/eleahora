---
import Layout from "../layouts/Layout.astro";
import ScrollAnimations from "../components/svelte/ScrollAnimations.svelte";
import { getHomePage, getSiteConfig, getAllTestimonios } from "../lib/keystatic";
import "../styles/global.css";

// Keystatic: datos del CMS con fallback a contenido actual
const home = await getHomePage();
const siteConfig = await getSiteConfig();
const testimonios = await getAllTestimonios(true);

// Fallbacks: si Keystatic no tiene datos, usar los textos actuales
const heroTitle = home?.heroTitle ?? "Bienvenido";
const heroSubtitle = home?.heroSubtitle ?? "Soy la voz que te recuerda que estás aquí.\nEn el presente. Meditación y Terapia Transpersonal. Mindfulness. Espiritualidad aterrizada.";
const heroCtaText = home?.heroCtaText ?? "Estoy aquí para ti";
const heroCtaLink = (home as any)?.heroCtaLink ?? "/sesiones";
const heroImage = home?.heroImage ?? "/images/home-hero-eleahora-01-tiny.webp";

const manifestoLabel = home?.manifestoLabel ?? "Manifiesto";
const manifestoTitle = home?.manifestoTitle ?? "Deja que el amor te regule.";
const manifestoBodyHtml = home?.manifestoBodyHtml ?? null;
const manifestoQuote = home?.manifestoQuote ?? "Soy estructura y soy caos. Soy servicio y soy soberanía. Deja que el amor te regule. Confía en el proceso.";
const manifestoImage = home?.manifestoImage ?? "/images/home-manifiesto-eleahora-01-tiny.webp";

const serviciosTitle = (home as any)?.serviciosTitle ?? "Estoy aquí para ti";

const mindfulnessLabel = home?.mindfulnessLabel ?? "Ciencia & Espíritu";
const mindfulnessTitle = home?.mindfulnessTitle ?? "Mindfulness como camino.";
const mindfulnessLead = home?.mindfulnessLead ?? "La meditación es una herramienta de neuroregulación. El mindfulness es una práctica que entrena la mente para volver al momento presente.";
const mindfulnessBody = home?.mindfulnessBody ?? "A través de la respiración, la atención plena y la consciencia corporal, el sistema nervioso aprende a salir del estado de alerta constante y a encontrar un nuevo equilibrio entre el hacer y el ser.";
const mindfulnessBenefitsTitle = home?.mindfulnessBenefitsTitle ?? "Beneficios de practicar mindfulness regularmente:";
const mindfulnessBenefits = home?.mindfulnessBenefits?.length ? home.mindfulnessBenefits : [
  "Reducir el estrés y la ansiedad.",
  "Mejorar la claridad mental y la concentración.",
  "Regular emociones intensas.",
  "Dormir mejor.",
  "Aumentar la creatividad y la toma de decisiones.",
];
const mindfulnessConclusion = home?.mindfulnessConclusion ?? "En un mundo que nos empuja constantemente hacia el ruido y la velocidad, la meditación se convierte en una forma de volver a uno mismo.";
const mindfulnessImage = home?.mindfulnessImage ?? "/images/sesion_maria_corallo_neima_pidal_161-tiny.webp";

const insightTimerUrl = siteConfig?.insightTimerUrl ?? "https://insighttimer.com/eleahora";

// Testimonios: usar datos de Keystatic o fallback hardcodeado
const testimoniosData = testimonios.length > 0 ? testimonios : null;
const serviceCards = (home as any)?.serviceCards?.length ? (home as any).serviceCards : [
  {
    title: 'Sesiones Eleahora',
    description: 'Acompañamiento terapéutico con Meditación + PNL, Terapia Angelical, Perlas de Eleahora, Clases de Meditación y Sesión Energética.',
    href: '/sesiones',
    arrow: '→',
    external: false,
  },
  {
    title: 'Workshop "Pienso, luego medito"',
    description: 'Experiencia team building para grupos y empresas con herramientas prácticas para volver al presente que ayudan a regular niveles de estrés y a potenciar el rendimiento.',
    href: '/workshop-empresas',
    arrow: '→',
    external: false,
  },
  {
    title: 'Meditaciones Guiadas',
    description: 'Escuchar en Insight Timer',
    href: 'insightTimer',
    arrow: '↗',
    external: true,
  },
];
const resolveHomeLink = (href: string) => href === 'insightTimer' ? insightTimerUrl : href;
---

<Layout
  title={(home as any)?.seoTitle ?? siteConfig?.siteTitle ?? "Eleahora | Terapia Transpersonal y Meditación en Madrid"}
  description={(home as any)?.seoDescription ?? siteConfig?.siteDescription ?? "Eleahora: Terapia Transpersonal, Meditación y Mindfulness con Maria Eleonora Corallo. Sesiones individuales, Terapia Angelical, PNL y workshop para empresas. Presencial en Madrid y online."}
  ogTitle={(home as any)?.ogTitle ?? "Eleahora — Terapia Transpersonal y Meditación"}
  ogImage={(home as any)?.ogImage ?? siteConfig?.ogImage ?? "/images/OG-images-eleahora-02.png"}
>
  <ScrollAnimations client:idle />

  <!-- Hero Section -->
  <section class="hero-section">
    <div class="hero-overlay"></div>
    <img
      src={heroImage}
      alt={(home as any)?.heroImageAlt ?? "Maria Eleonora Corallo, terapeuta transpersonal y guía de meditación de Eleahora"}
      class="hero-bg gsap-parallax"
    />

    <div class="max-w-screen hero-content">
      <div class="hero-text-container">
        <h2 class="gsap-reveal text-accent hero-accent">{heroTitle}</h2>
        <h1 class="gsap-hero-reveal hero-title">
          {heroSubtitle.split('\n')[0]}
        </h1>

        <div class="gsap-hero-reveal hero-text-wrapper">
          <p class="hero-subtitle">
            {heroSubtitle.split('\n').slice(1).join('\n')}
          </p>
          <div class="hero-actions">
            <a href={heroCtaLink} class="btn-primary">{heroCtaText}</a>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- Manifiesto -->
  <section id="manifiesto" class="manifiesto-section">
    <div class="max-w-screen manifiesto-grid">
      <div class="manifiesto-text">
        <span class="gsap-reveal text-accent section-label">{manifestoLabel}</span>
        <h2 class="gsap-reveal section-title">{manifestoTitle}</h2>
        <div class="gsap-reveal section-body">
          {manifestoBodyHtml ? (
            <div set:html={manifestoBodyHtml} />
          ) : (
            <>
              <p>
                Durante años creí que la estructura y lo sutil eran opuestas. Vivía
                entre el deber ser y el anhelo de algo más grande. Hasta que entendí
                que el verdadero milagro ocurre cuando los pies están bien plantados
                en la tierra y el corazón abierto al cielo.
              </p>
              <p>
                En Eleahora la espiritualidad es aterrizada, no es un escape, es una
                herramienta. Usamos la mente (PNL y Meditación) para traducir el
                alma (Ángeles). Porque tu proceso no necesita ser perfecto, solo
                necesita ser tuyo.
              </p>
            </>
          )}
          <blockquote class="gsap-reveal manifiesto-quote">
            "{manifestoQuote}"
          </blockquote>
        </div>
      </div>
      <div class="manifiesto-image-wrapper gsap-reveal">
        <img
          src={manifestoImage}
          alt={(home as any)?.manifestoImageAlt ?? "Sesión de meditación y terapia transpersonal de Eleahora — Manifiesto"}
          class="manifiesto-img"
        />
      </div>
    </div>
  </section>

  <!-- Servicios -->
  <section class="services-section">
    <div class="max-w-screen">
      <div class="services-header gsap-reveal">
        <h2 class="section-title text-light">{serviciosTitle}</h2>
      </div>

      <div class="services-grid">
        {serviceCards.map((card: { title: string; description: string; href: string; arrow?: string; external?: boolean }, index: number) => (
          <div class="service-card-wrapper gsap-reveal" data-gsap-delay={index ? String(index * 0.15) : undefined}>
            <a
              href={resolveHomeLink(card.href)}
              target={card.external ? "_blank" : undefined}
              rel={card.external ? "noopener noreferrer" : undefined}
              class="service-card"
            >
              <div class="service-content">
                <h3>{card.title}</h3>
                <p>{card.description}</p>
              </div>
              <div class="service-arrow">{card.arrow ?? "→"}</div>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>



  <!-- Mindfulness SEO -->
  <section id="mindfulness" class="mindfulness-section">
    <div class="max-w-screen">
      <div class="mindfulness-header">
        <span class="gsap-reveal text-accent section-label"
          >{mindfulnessLabel}</span
        >
        <h2 class="gsap-reveal section-title">{mindfulnessTitle}</h2>
      </div>

      <div class="mindfulness-grid">
        <div class="mindfulness-image-wrapper gsap-reveal">
          <img
              src={mindfulnessImage}
            alt={(home as any)?.mindfulnessImageAlt ?? "Práctica de mindfulness y meditación consciente con Eleahora"}
            class="mindfulness-img"
          />
        </div>



        <div class="mindfulness-text">
          <div class="gsap-reveal section-body">
            <p class="mindfulness-lead">
              {mindfulnessLead}
            </p>
            <p class="mindfulness-desc">
              {mindfulnessBody}
            </p>

            <div class="mindfulness-benefits-card">
              <h3 class="benefits-title">{mindfulnessBenefitsTitle}</h3>
              <ul class="mindfulness-benefits">
                {mindfulnessBenefits.map((benefit: string) => (
                  <li>{benefit}</li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>

      <div class="mindfulness-footer gsap-reveal">
        <p class="mindfulness-conclusion">
          "{mindfulnessConclusion}"
        </p>
      </div>
    </div>
  </section>

  <!-- Testimonios -->
  <section id="testimonios" class="testimonials-section">
    <div class="max-w-screen">
      <div class="section-header gsap-reveal">
        <h2 class="section-title">{(home as any)?.testimonialsTitle ?? "Testimonios"}</h2>
      </div>

      <div class="testimonials-grid">
        {testimoniosData && (
          testimoniosData.map((t) => (
            <article class={`testimonial-card testimonial-${(t.entry as any)?.accentColor || 'sage'} gsap-reveal`}>
              <p class="testimonial-text">{t.entry.quote}</p>
              <p class="testimonial-author">— {t.entry.name}</p>
            </article>
          ))
        )}
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero Section */
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background-color: var(--color-background);
  }

  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    object-fit: cover;
    object-position: 70% 30%;
    z-index: 0;
    opacity: 1; /* Imagen pura, radiante y a full opacidad */
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    /* Oscurecer ligeramente el lado izquierdo para texto claro sobre fondo oscuro */
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.65) 0%,
      rgba(0, 0, 0, 0.45) 30%,
      transparent 60%
    );
    z-index: 1;
    pointer-events: none;
  }
  /* Removed mobile white gradient override to preserve dark overlay on all viewports */

  .hero-content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding-top: 8rem; /* Separar más del header */
    padding-bottom: 4rem;
  }

  .hero-text-container {
    max-width: 800px;
    padding: 2rem 0;
  }

  .hero-accent {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    margin-bottom: 0.5rem;
    display: block;
    color: var(--color-background);
    line-height: 1;
    font-family: var(--font-primary);
    text-transform: lowercase;
  }

  .hero-accent::first-letter {
    font-family: var(--font-accent);
    text-transform: uppercase;
    font-size: 1.5em;
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--color-background);
    margin-bottom: 1.5rem;
    text-shadow: 0px 4px 20px rgba(0, 0, 0, 0.6);
  }

  .hero-text-wrapper {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .hero-text-wrapper {
      flex-direction: column; /* Apilar para no cortar el texto */
      align-items: flex-start;
    }
  }

  .hero-subtitle {
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    line-height: 1.6;
    max-width: 500px;
    margin-bottom: 0;
    font-weight: 500;
    color: var(--color-background); /* Texto claro para fondo oscuro */
  }

  /* Hero-specific button styles for dark hero background */
  .hero-section .btn-primary {
    background-color: transparent;
    color: var(--color-background);
    border-color: rgba(253, 251, 236, 0.35);
  }

  .hero-section .btn-primary:hover {
    background-color: var(--color-background);
    color: var(--color-primary-dark);
  }

  /* General typography layout */
  .section-label {
    font-size: 2.5rem;
    display: block;
    margin-bottom: 1rem;
    font-family: var(--font-primary);
    text-transform: lowercase;
  }

  .section-label::first-letter {
    font-family: var(--font-accent);
    text-transform: uppercase;
    font-size: 1.5em;
  }

  .section-title {
    font-size: clamp(2.5rem, 4vw, 4rem);
    line-height: 1.1;
    margin-bottom: 2.5rem;
  }

  .section-body p {
    font-size: 1.2rem;
    line-height: 1.8;
  }

  /* Manifiesto */
  .manifiesto-section {
    padding: 8rem 0;
    background-color: var(--color-background);
  }

  .manifiesto-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .manifiesto-grid {
      grid-template-columns: 1.2fr 1fr;
      gap: 6rem;
    }
  }

  .manifiesto-quote {
    font-family: var(--font-primary);
    font-size: 1.75rem;
    color: var(--color-accent-red);
    font-style: italic;
    border-left: 3px solid var(--color-accent-red);
    padding-left: 2rem;
    margin-top: 3rem;
    line-height: 1.4;
  }

  .manifiesto-image-wrapper {
    border-radius: 20px 20px 20px 20px; /* organically shaped or just rounded */
    overflow: hidden;
    position: relative;
    aspect-ratio: 4/5;
  }

  .manifiesto-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Servicios Dark Section */
  .services-section {
    padding: 8rem 0;
    background-color: var(--color-accent-red);
    color: var(--color-background);
  }

  .text-light {
    color: var(--color-background);
  }

  .light-btn {
    border-color: rgba(253, 251, 236, 0.3);
    color: var(--color-background);
  }

  .light-btn:hover {
    background-color: var(--color-background);
    color: var(--color-primary-dark);
  }

  .services-header {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-bottom: 5rem;
  }

  @media (min-width: 768px) {
    .services-header {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
    }
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .service-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 3rem 2rem;
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(253, 251, 236, 0.1);
    border-radius: 12px;
    height: 100%;
    min-height: 350px;
    transition: background-color 0.3s ease, transform 0.3s ease;
    will-change: transform, background-color;
  }

  .service-card:hover {
    background-color: rgba(255, 255, 255, 0.08);
    transform: translateY(-5px);
  }

  .service-content h3 {
    font-size: 1.75rem;
    color: var(--color-background);
    margin-bottom: 1.5rem;
  }

  .service-content p {
    color: rgba(253, 251, 236, 0.7);
    font-size: 1.05rem;
  }

  .service-arrow {
    font-size: 2rem;
    color: var(--color-earth);
    margin-top: 2rem;
    align-self: flex-end;
    transition: transform 0.3s ease;
  }

  .service-card:hover .service-arrow {
    transform: translateX(5px);
  }

  /* Mindfulness SEO */
  .mindfulness-section {
    padding: 8rem 0;
    background-color: var(--color-background);
  }

  .mindfulness-header {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 4rem;
  }

  .mindfulness-header .section-label {
    margin-bottom: 0.5rem;
  }

  .mindfulness-header .section-title {
    margin-bottom: 0;
  }

  .mindfulness-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .mindfulness-grid {
      grid-template-columns: 1fr 1.2fr;
      gap: 6rem;
    }
  }

  .mindfulness-image-wrapper {
    order: 2;
    border-radius: 20px;
    overflow: hidden;
    position: relative;
    aspect-ratio: 3/4;
  }

  @media (min-width: 1024px) {
    .mindfulness-image-wrapper {
      order: 1;
    }
    .mindfulness-text {
      order: 2;
    }
  }

  .mindfulness-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .text-primary-dark {
    color: var(--color-primary-dark);
    font-weight: 600;
  }

  .mindfulness-lead {
    font-size: 1.4rem !important;
    line-height: 1.6 !important;
    margin-bottom: 1.5rem;
    color: var(--color-primary-dark);
  }

  .mindfulness-desc {
    font-size: 1.1rem !important;
    line-height: 1.8 !important;
    opacity: 0.85;
    margin-bottom: 2rem;
  }

  .mindfulness-benefits-card {
    background: rgba(255, 255, 255, 0.4);
    border: 1px solid rgba(187, 137, 107, 0.2);
    border-radius: 16px;
    padding: 2rem;
    margin: 2rem 0;
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.02);
  }

  .benefits-title {
    font-family: var(--font-primary, system-ui);
    font-size: 1.2rem;
    color: var(--color-accent-purple);
    margin-bottom: 1.25rem;
    letter-spacing: 0.5px;
  }

  .mindfulness-benefits {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
  }

  .mindfulness-benefits li {
    font-family: system-ui, sans-serif;
    font-size: 1.05rem;
    color: var(--color-primary-dark);
    padding-left: 2rem;
    position: relative;
    opacity: 0.9;
    line-height: 1.5;
  }

  .mindfulness-benefits li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 2px;
    width: 20px;
    height: 20px;
    background-image: url('/images/favicon.png');
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
  }

  /* Testimonials styles */
  .testimonials-section {
    padding: 6rem 0;
    background-color: var(--color-background);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .testimonials-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .testimonial-card {
    background: rgba(59, 38, 57, 0.03);
    border: 1px solid rgba(59, 38, 57, 0.06);
    padding: 2rem;
    border-radius: 12px;
    min-height: 220px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .testimonial-text {
    color: var(--color-primary-dark);
    font-size: 0.98rem;
    line-height: 1.6;
    margin-bottom: 1rem;
    opacity: 0.95;
    white-space: pre-line;
  }

  .testimonial-author {
    font-weight: 700;
    color: var(--color-accent-red);
    font-size: 0.95rem;
  }

    .testimonial-sage {
      border-left: 3px solid #566443;
      background: rgba(86, 100, 67, 0.04);
    }
    .testimonial-sage .testimonial-author {
      color: #566443;
    }

    .testimonial-red {
      border-left: 3px solid #8c0703;
      background: rgba(140, 7, 3, 0.04);
    }
    .testimonial-red .testimonial-author {
      color: #8c0703;
    }

    .testimonial-purple {
      border-left: 3px solid #6d4492;
      background: rgba(109, 68, 146, 0.04);
    }
    .testimonial-purple .testimonial-author {
      color: #6d4492;
    }
  .mindfulness-footer {
    max-width: 900px;
    margin: 5rem auto 0;
    text-align: center;
  }

  .mindfulness-conclusion {
    font-family: var(--font-primary, sans-serif) !important;
    font-size: clamp(1.5rem, 2.5vw, 2rem) !important;
    color: var(--color-accent-red) !important;
    opacity: 1 !important;
    line-height: 1.4 !important;
    margin: 0;
  }


</style>
