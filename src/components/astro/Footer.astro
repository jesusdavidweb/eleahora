---
// Footer.astro
import MeditationModal from '../svelte/MeditationModal.svelte';
import { getGlobalContent, getSiteConfig } from '../../lib/keystatic';

const currentYear = new Date().getFullYear();

// Keystatic: configuración global
const siteConfig = await getSiteConfig();
const globalContent = await getGlobalContent();
const bookingUrl = siteConfig?.calLink ?? 'https://scheduler.zoom.us/maria-eleonora-051exv/sesi-n-eleahora';
const instagramUrl = siteConfig?.instagramUrl ?? 'https://www.instagram.com/eleahora/';
const linkedinUrl = (siteConfig as any)?.linkedinUrl ?? 'https://www.linkedin.com/in/maria-eleonora-corallo-16266165/';
const insightTimerUrl = siteConfig?.insightTimerUrl ?? 'https://insighttimer.com/eleahora';
const whatsappUrl = `https://wa.me/${(siteConfig?.phoneWhatsapp ?? '+34605373782').replace('+', '')}`;
const footerLogo = globalContent?.footerLogo ?? '/images/logo-white.png';
const footerLogoAlt = globalContent?.footerLogoAlt ?? 'Eleahora';
const footerExploreLinks = globalContent?.footerExploreLinks?.length ? globalContent.footerExploreLinks : [
  { label: 'Inicio', href: '/' },
  { label: 'Sobre Mí', href: '/about' },
  { label: 'Manifiesto', href: '/#manifiesto' },
  { label: 'Sesiones y servicios', href: '/sesiones' },
  { label: 'Workshop Empresas', href: '/workshop-empresas' },
  { label: 'Mindfulness', href: '/#mindfulness' },
  { label: 'Contacto', href: '/contacto' },
];
const footerCreditsLinks = globalContent?.footerCreditsLinks?.length ? globalContent.footerCreditsLinks : [
  { label: 'Amorchi House', href: 'http://amorchihouse.com/' },
  { label: '@jesusdavidweb', href: 'https://jesusdavid.net/' },
];
const footerLegalLinks = globalContent?.footerLegalLinks?.length ? globalContent.footerLegalLinks : [
  { label: 'Aviso Legal', href: '/legal/aviso-legal' },
  { label: 'Privacidad', href: '/legal/politica-de-privacidad' },
  { label: 'Cookies', href: '/legal/politica-de-cookies' },
];
const footerContactLinks = globalContent?.footerContactLinks?.length ? globalContent.footerContactLinks : [
  { label: 'Agenda una Sesion', href: 'booking', external: true },
  { label: 'Instagram', href: 'instagram', external: true },
  { label: 'LinkedIn', href: 'linkedin', external: true },
  { label: 'Meditaciones Guiadas', href: 'insightTimer', external: true },
  { label: 'WhatsApp', href: 'whatsapp', external: true },
];
const footerContactLabel = (href: string, fallback: string) => {
  const link = footerContactLinks.find((item: { href: string }) => item.href === href);
  return link?.label ?? fallback;
};
---

<footer class="eleahora-footer">
  <div class="footer-container max-w-screen">
    <div class="footer-grid">
      <div class="footer-brand">
        <img src={footerLogo} alt={footerLogoAlt} class="footer-logo" />
        <p class="brand-slogan text-accent">{globalContent?.footerSlogan ?? 'Soy la voz que te recuerda que estás aquí.'}</p>
        <button
          class="footer-meditation-cta"
          type="button"
          data-meditation-modal-trigger
          aria-label={globalContent?.footerMeditationCtaAriaLabel ?? 'Abrir meditación gratuita de Insight Timer en un pop-up'}
        >
          {globalContent?.footerMeditationCtaText ?? 'Escuchar meditación gratuita'}
        </button>
      </div>
      
      <div class="footer-links">
        <h3 class="footer-title">{globalContent?.footerExploreTitle ?? 'Explora'}</h3>
        <nav aria-label="Footer Navigation">
          <ul>
            {footerExploreLinks.map((link: { label: string; href: string }) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </nav>
      </div>
      
      <div class="footer-links">
        <h3 class="footer-title">{globalContent?.footerLegalTitle ?? 'Legal'}</h3>
        <nav aria-label="Legal">
          <ul>
            {footerLegalLinks.map((link: { label: string; href: string }) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </nav>
      </div>
      
      <div class="footer-contact">
        <h3 class="footer-title">{globalContent?.footerContactTitle ?? 'Conecta'}</h3>
        <ul>
          <li>
            <a
              class="social-link social-link--cal"
              href={bookingUrl}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Agenda una sesion en Cal.com"
            >
              <svg class="social-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path
                  d="M3 9H21M7 3V5M17 3V5M11.9976 12.7119C11.2978 11.9328 10.1309 11.7232 9.25414 12.4367C8.37738 13.1501 8.25394 14.343 8.94247 15.1868C9.33119 15.6632 10.2548 16.4983 10.9854 17.1353C11.3319 17.4374 11.5051 17.5885 11.7147 17.6503C11.8934 17.703 12.1018 17.703 12.2805 17.6503C12.4901 17.5885 12.6633 17.4374 13.0098 17.1353C13.7404 16.4983 14.664 15.6632 15.0527 15.1868C15.7413 14.343 15.6329 13.1426 14.7411 12.4367C13.8492 11.7307 12.6974 11.9328 11.9976 12.7119ZM6.2 21H17.8C18.9201 21 19.4802 21 19.908 20.782C20.2843 20.5903 20.5903 20.2843 20.782 19.908C21 19.4802 21 18.9201 21 17.8V8.2C21 7.07989 21 6.51984 20.782 6.09202C20.5903 5.71569 20.2843 5.40973 19.908 5.21799C19.4802 5 18.9201 5 17.8 5H6.2C5.0799 5 4.51984 5 4.09202 5.21799C3.71569 5.40973 3.40973 5.71569 3.21799 6.09202C3 6.51984 3 7.07989 3 8.2V17.8C3 18.9201 3 19.4802 3.21799 19.908C3.40973 20.2843 3.71569 20.5903 4.09202 20.782C4.51984 21 5.07989 21 6.2 21Z"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.7"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
              <span>{footerContactLabel('booking', 'Agenda una Sesion')}</span>
            </a>
          </li>
          <li>
            <a
              class="social-link social-link--instagram"
              href={instagramUrl}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Instagram de Eleahora"
            >
              <svg class="social-icon" viewBox="0 0 20 20" aria-hidden="true" focusable="false">
                <g fill="currentColor" fill-rule="evenodd">
                  <g transform="translate(-340 -7439)">
                    <g transform="translate(56 160)">
                      <path d="M289.869652 7279.12273C288.241769 7279.19618 286.830805 7279.5942 285.691486 7280.72871C284.548187 7281.86918 284.155147 7283.28558 284.081514 7284.89653C284.035742 7285.90201 283.768077 7293.49818 284.544207 7295.49028C285.067597 7296.83422 286.098457 7297.86749 287.454694 7298.39256C288.087538 7298.63872 288.809936 7298.80547 289.869652 7298.85411C298.730467 7299.25511 302.015089 7299.03674 303.400182 7295.49028C303.645956 7294.859 303.815113 7294.1374 303.86188 7293.08031C304.26686 7284.19677 303.796207 7282.27117 302.251908 7280.72871C301.027016 7279.50685 299.5862 7278.67508 289.869652 7279.12273M289.951245 7297.06748C288.981083 7297.0238 288.454707 7296.86201 288.103459 7296.72603C287.219865 7296.3826 286.556174 7295.72155 286.214876 7294.84312C285.623823 7293.32944 285.819846 7286.14023 285.872583 7284.97693C285.924325 7283.83745 286.155174 7282.79624 286.959165 7281.99226C287.954203 7280.99968 289.239792 7280.51332 297.993144 7280.90837C299.135448 7280.95998 300.179243 7281.19026 300.985224 7281.99226C301.980262 7282.98483 302.473801 7284.28014 302.071806 7292.99991C302.028024 7293.96767 301.865833 7294.49274 301.729513 7294.84312C300.829003 7297.15085 298.757333 7297.47145 289.951245 7297.06748M298.089663 7283.68956C298.089663 7284.34665 298.623998 7284.88065 299.283709 7284.88065C299.943419 7284.88065 300.47875 7284.34665 300.47875 7283.68956C300.47875 7283.03248 299.943419 7282.49847 299.283709 7282.49847C298.623998 7282.49847 298.089663 7283.03248 298.089663 7283.68956M288.862673 7288.98792C288.862673 7291.80286 291.150266 7294.08479 293.972194 7294.08479C296.794123 7294.08479 299.081716 7291.80286 299.081716 7288.98792C299.081716 7286.17298 296.794123 7283.89205 293.972194 7283.89205C291.150266 7283.89205 288.862673 7286.17298 288.862673 7288.98792M290.655732 7288.98792C290.655732 7287.16159 292.140329 7285.67967 293.972194 7285.67967C295.80406 7285.67967 297.288657 7287.16159 297.288657 7288.98792C297.288657 7290.81525 295.80406 7292.29716 293.972194 7292.29716C292.140329 7292.29716 290.655732 7290.81525 290.655732 7288.98792" />
                    </g>
                  </g>
                </g>
              </svg>
              <span>{footerContactLabel('instagram', 'Instagram')}</span>
            </a>
          </li>
          <li>
            <a
              class="social-link social-link--linkedin"
              href={linkedinUrl}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn de Eleahora"
            >
              <svg class="social-icon" viewBox="0 0 20 20" aria-hidden="true" focusable="false">
                <g fill="currentColor" fill-rule="evenodd">
                  <g transform="translate(-180 -7479)">
                    <g transform="translate(56 160)">
                      <path d="M144 7339H140V7332.001C140 7330.081 139.153 7329.01 137.634 7329.01C135.981 7329.01 135 7330.126 135 7332.001V7339H131V7326H135V7327.462C135 7327.462 136.255 7325.26 139.083 7325.26C141.912 7325.26 144 7326.986 144 7330.558V7339ZM126.442 7323.921C125.093 7323.921 124 7322.819 124 7321.46C124 7320.102 125.093 7319 126.442 7319C127.79 7319 128.883 7320.102 128.883 7321.46C128.884 7322.819 127.79 7323.921 126.442 7323.921ZM124 7339H129V7326H124V7339Z" />
                    </g>
                  </g>
                </g>
              </svg>
              <span>{footerContactLabel('linkedin', 'LinkedIn')}</span>
            </a>
          </li>
          <li>
            <a
              class="social-link social-link--insight"
              href={insightTimerUrl}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Insight Timer de Eleahora"
            >
              <svg class="social-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M14.5 4.5C14.5 5.88071 13.3807 7 12 7C10.6193 7 9.5 5.88071 9.5 4.5C9.5 3.11929 10.6193 2 12 2C13.3807 2 14.5 3.11929 14.5 4.5Z" fill="none" stroke="currentColor" stroke-width="1.5" />
                <path d="M3 17L5.58887 15.6918C5.84084 15.5645 6 15.3043 6 15.0196C6 12.0802 8.1377 9.56573 11.0067 9.0825C11.6598 8.9725 12.3402 8.9725 12.9933 9.0825C13.3404 9.14096 13.6768 9.22916 14 9.34423M21 17L18.4111 15.6918C18.1592 15.5645 18 15.3043 18 15.0196C18 13.9268 17.7045 12.8928 17.1859 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M9.5 16L8.45827 17.389C8.42647 17.4314 8.41057 17.4526 8.39456 17.4728C8.13149 17.8053 7.76956 18.0456 7.36102 18.1591C7.33616 18.166 7.31042 18.1724 7.25902 18.1852L5.77423 18.5564C4.7315 18.8171 4 19.754 4 20.8288C4 21.4757 4.52435 22 5.17116 22H6.72727C7.32654 22 7.62617 22 7.917 21.9658C8.59721 21.8859 9.25375 21.667 9.84589 21.3229C10.0991 21.1757 10.3388 20.9959 10.8182 20.6364L11 20.5M11 20.5L13 19M11 20.5L13.5397 21.4524C14.1491 21.6809 14.4539 21.7952 14.7688 21.8688C14.9318 21.9069 15.0966 21.9368 15.2625 21.9583C15.5832 22 15.9087 22 16.5596 22H18.8288C19.4757 22 20 21.4757 20 20.8288C20 19.754 19.2685 18.8171 18.2258 18.5564L16.741 18.1852C16.6896 18.1724 16.6638 18.166 16.639 18.1591C16.2304 18.0456 15.8685 17.8053 15.6054 17.4728C15.5895 17.4526 15.5735 17.4313 15.5417 17.389L14.5 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span>{footerContactLabel('insightTimer', 'Meditaciones Guiadas')}</span>
            </a>
          </li>
          <li>
            <a
              class="social-link social-link--whatsapp"
              href={whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="WhatsApp de Eleahora"
            >
              <svg class="social-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path
                  fill-rule="evenodd"
                  clip-rule="evenodd"
                  d="M3.50002 12C3.50002 7.30558 7.3056 3.5 12 3.5C16.6944 3.5 20.5 7.30558 20.5 12C20.5 16.6944 16.6944 20.5 12 20.5C10.3278 20.5 8.77127 20.0182 7.45798 19.1861C7.21357 19.0313 6.91408 18.9899 6.63684 19.0726L3.75769 19.9319L4.84173 17.3953C4.96986 17.0955 4.94379 16.7521 4.77187 16.4751C3.9657 15.176 3.50002 13.6439 3.50002 12ZM12 1.5C6.20103 1.5 1.50002 6.20101 1.50002 12C1.50002 13.8381 1.97316 15.5683 2.80465 17.0727L1.08047 21.107C0.928048 21.4637 0.99561 21.8763 1.25382 22.1657C1.51203 22.4552 1.91432 22.5692 2.28599 22.4582L6.78541 21.1155C8.32245 21.9965 10.1037 22.5 12 22.5C17.799 22.5 22.5 17.799 22.5 12C22.5 6.20101 17.799 1.5 12 1.5ZM14.2925 14.1824L12.9783 15.1081C12.3628 14.7575 11.6823 14.2681 10.9997 13.5855C10.2901 12.8759 9.76402 12.1433 9.37612 11.4713L10.2113 10.7624C10.5697 10.4582 10.6678 9.94533 10.447 9.53028L9.38284 7.53028C9.23954 7.26097 8.98116 7.0718 8.68115 7.01654C8.38113 6.96129 8.07231 7.046 7.84247 7.24659L7.52696 7.52195C6.76823 8.18414 6.3195 9.2723 6.69141 10.3741C7.07698 11.5163 7.89983 13.314 9.58552 14.9997C11.3991 16.8133 13.2413 17.5275 14.3186 17.8049C15.1866 18.0283 16.008 17.7288 16.5868 17.2572L17.1783 16.7752C17.4313 16.5691 17.5678 16.2524 17.544 15.9269C17.5201 15.6014 17.3389 15.308 17.0585 15.1409L15.3802 14.1409C15.0412 13.939 14.6152 13.9552 14.2925 14.1824Z"
                  fill="currentColor"
                />
              </svg>
              <span>{footerContactLabel('whatsapp', 'WhatsApp')}</span>
            </a>
          </li>
        </ul>
      </div>
    </div>
    
    <div class="footer-bottom">
      <p>&copy; {currentYear} {globalContent?.footerCopyright ?? 'Eleahora. Todos los derechos reservados.'}</p>
      <p class="credits">
        {globalContent?.footerCreditsPrefix ?? 'Hecho con amor por'}{' '}
        {footerCreditsLinks.map((link: { label: string; href: string }, index: number) => (
          <>
            {index > 0 && ' y '}
            <a href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a>
          </>
        ))}
      </p>
    </div>
  </div>
</footer>

<MeditationModal
  title={globalContent?.meditationModalTitle ?? 'Meditación gratuita'}
  closeText={globalContent?.meditationModalCloseText ?? 'Cerrar'}
  closeAriaLabel={globalContent?.meditationModalCloseAriaLabel ?? 'Cerrar meditación'}
  iframeTitle={globalContent?.meditationModalIframeTitle ?? 'Insight Timer Embed: Maria Eleonora Corallo'}
  embedUrl={globalContent?.meditationModalEmbedUrl ?? 'https://widgets.insighttimer.com/publisher/Qi5htL7vZhRNNN9BOvdTdSUt6E32?created_at=1776166254'}
  client:idle
/>

<style>
  .eleahora-footer {
    background-color: var(--color-theme-dynamic);
    color: var(--color-background);
    padding: 6rem 0 2rem;
    margin-top: 4rem;
  }
  
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    margin-bottom: 4rem;
  }
  
  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1fr;
    }
  }
  
  .footer-logo {
    height: 40px !important;
    width: auto !important;
    margin-bottom: 1.5rem;
  }
  
  .brand-slogan {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--color-earth); /* To contrast nicely against dark background */
    font-family: var(--font-primary);
    text-transform: lowercase;
  }

  .brand-slogan::first-letter {
    font-family: var(--font-accent);
    text-transform: uppercase;
    font-size: 1.5em;
  }

  .footer-meditation-cta {
    appearance: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.5rem;
    padding: 0.6rem 1.1rem;
    border-radius: 999px;
    border: 1px solid transparent;
    background-color: var(--color-background);
    color: var(--color-primary-dark);
    font-family: var(--font-base);
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: var(--transition-smooth);
  }

  .footer-meditation-cta:hover {
    background-color: var(--color-earth);
    color: var(--color-primary-dark);
    border-color: var(--color-background);
  }

  .footer-meditation-cta:focus-visible {
    outline: 2px solid var(--color-background);
    outline-offset: 3px;
    background-color: var(--color-earth);
    color: var(--color-primary-dark);
  }
  
  .brand-sub {
    font-size: 1rem;
    color: var(--color-background);
    opacity: 0.8;
  }
  
  .footer-title {
    color: var(--color-earth);
    font-size: 1.25rem;
    margin-bottom: 1.5rem;
    font-family: var(--font-primary);
  }
  
  .footer-links ul,
  .footer-contact ul {
    list-style: none;
    padding: 0;
  }
  
  .footer-links li,
  .footer-contact li {
    margin-bottom: 0.75rem;
  }
  
  .footer-links a,
  .footer-contact a {
    color: var(--color-background);
    opacity: 0.8;
    transition: var(--transition-smooth);
    font-family: system-ui, sans-serif;
  }

  .footer-contact .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    line-height: 1.2;
  }

  .social-icon {
    width: 1.05rem;
    height: 1.05rem;
    flex-shrink: 0;
    fill: currentColor;
  }


  
  .footer-links a:hover,
  .footer-contact a:hover {
    opacity: 1;
    color: var(--color-earth);
  }

  .footer-contact a:focus-visible {
    outline: 2px solid var(--color-earth);
    outline-offset: 3px;
    border-radius: 2px;
  }
  
  .footer-bottom {
    border-top: 1px solid rgba(253, 251, 236, 0.2); /* Semi-transparent color-background */
    padding-top: 2rem;
    text-align: center;
  }
  
  .footer-bottom p {
    color: var(--color-background);
    opacity: 0.6;
    font-size: 0.875rem;
    margin-bottom: 0.5rem;
  }

  .footer-bottom p:last-child {
    margin-bottom: 0;
  }

  .credits a {
    color: var(--color-earth);
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .credits a:hover {
    opacity: 0.8;
  }
</style>
