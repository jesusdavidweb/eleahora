---
import MeditationModal from '../svelte/MeditationModal.svelte';
import { getSiteConfig } from '../../lib/keystatic';

const currentYear = new Date().getFullYear();
const site = await getSiteConfig();

const whatsappNumber = site?.phoneWhatsapp ?? '+34605373782';
const calLink = site?.calLink ?? 'https://cal.eu/eleahora/sesiones';
const instagramUrl = site?.instagramUrl ?? 'https://www.instagram.com/eleahora/';
const insightUrl = site?.insightTimerUrl ?? 'https://insighttimer.com/eleahora';
---

<footer class="eleahora-footer">
  <div class="footer-container max-w-screen">
    <div class="footer-grid">
      <div class="footer-brand">
        <img src="/images/logo-white.png" alt="Eleahora" class="footer-logo" />
        <p class="brand-slogan text-accent">Soy la voz que te recuerda que estás aquí.</p>
        <button
          class="footer-meditation-cta"
          type="button"
          data-meditation-modal-trigger
          aria-label="Abrir meditación gratuita de Insight Timer en un pop-up"
        >
          Escuchar meditación gratuita
        </button>
      </div>

      <div class="footer-links">
        <h3 class="footer-title">Explora</h3>
        <nav aria-label="Footer Navigation">
          <ul>
            <li><a href="/">Inicio</a></li>
            <li><a href="/about">Sobre Mí</a></li>
            <li><a href="/#manifiesto">Manifiesto</a></li>
            <li><a href="/sesiones">Sesiones y servicios</a></li>
            <li><a href="/workshop-empresas">Workshop Empresas</a></li>
            <li><a href="/#mindfulness">Mindfulness</a></li>
            <li><a href="/contacto">Contacto</a></li>
          </ul>
        </nav>
      </div>

      <div class="footer-contact">
        <h3 class="footer-title">Conecta</h3>
        <ul>
          <li><a href={calLink} target="_blank" rel="noopener noreferrer">Agenda una Sesión</a></li>
          <li><a href={instagramUrl} target="_blank" rel="noopener noreferrer">Instagram</a></li>
          <li><a href="https://www.linkedin.com/in/maria-eleonora-corallo-16266165/" target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
          <li><a href={insightUrl} target="_blank" rel="noopener noreferrer">Meditaciones Guiadas</a></li>
          <li><a href={`https://wa.me/${whatsappNumber.replace(/[^0-9+]/g, '')}`} target="_blank" rel="noopener noreferrer">WhatsApp</a></li>
        </ul>
      </div>

      <div class="footer-legal-col">
        <h3 class="footer-title">Legal</h3>
        <nav aria-label="Legal Navigation">
          <ul>
            <li><a href="/legal/aviso-legal">Aviso Legal</a></li>
            <li><a href="/legal/politica-de-privacidad">Privacidad</a></li>
            <li><a href="/legal/politica-de-cookies">Cookies</a></li>
          </ul>
        </nav>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} Eleahora. Todos los derechos reservados.</p>
      <p class="credits">
        Hecho con amor 🤍 por <a href="http://amorchihouse.com/" target="_blank" rel="noopener noreferrer">Amorchi House</a> y <a href="https://jesusdavid.net/" target="_blank" rel="noopener noreferrer">@jesusdavidweb</a>
      </p>
    </div>
  </div>
</footer>

<MeditationModal client:idle />

<style>
  .eleahora-footer {
    background-color: var(--color-theme-dynamic);
    color: var(--color-background);
    padding: 6rem 0 2rem;
    margin-top: 4rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    margin-bottom: 4rem;
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: minmax(0, 2fr) minmax(0, 1fr) minmax(0, 1fr) minmax(0, 0.85fr);
      align-items: start;
    }
  }

  .footer-logo {
    height: 40px !important;
    width: auto !important;
    margin-bottom: 1.5rem;
  }

  .brand-slogan {
    max-width: 18ch;
    margin-bottom: 1rem;
    color: var(--color-earth);
    font-family: var(--font-primary);
    font-size: 1.5rem;
    line-height: 1.15;
    text-transform: lowercase;
  }

  .brand-slogan::first-letter {
    font-family: var(--font-accent);
    font-size: 1.5em;
    text-transform: uppercase;
  }

  .footer-meditation-cta {
    appearance: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.5rem;
    padding: 0.6rem 1.1rem;
    border: 1px solid transparent;
    border-radius: 999px;
    background-color: var(--color-background);
    color: var(--color-primary-dark);
    cursor: pointer;
    font-family: var(--font-base);
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: var(--transition-smooth);
  }

  .footer-meditation-cta:hover,
  .footer-meditation-cta:focus-visible {
    border-color: var(--color-background);
    background-color: var(--color-earth);
    color: var(--color-primary-dark);
  }

  .footer-meditation-cta:focus-visible {
    outline: 2px solid var(--color-background);
    outline-offset: 3px;
  }

  .footer-title {
    margin-bottom: 1.5rem;
    color: var(--color-earth);
    font-family: var(--font-primary);
    font-size: 1.25rem;
  }

  .footer-links ul,
  .footer-contact ul,
  .footer-legal-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li,
  .footer-contact li,
  .footer-legal-col li {
    margin-bottom: 0.75rem;
  }

  .footer-links a,
  .footer-contact a,
  .footer-legal-col a {
    color: var(--color-background);
    font-family: var(--font-base);
    opacity: 0.8;
    text-decoration: none;
    transition: var(--transition-smooth);
  }

  .footer-links a:hover,
  .footer-contact a:hover,
  .footer-legal-col a:hover {
    color: var(--color-earth);
    opacity: 1;
  }

  .footer-links a:focus-visible,
  .footer-contact a:focus-visible,
  .footer-legal-col a:focus-visible {
    outline: 2px solid var(--color-earth);
    outline-offset: 3px;
    border-radius: 2px;
  }

  .footer-bottom {
    border-top: 1px solid rgba(253, 251, 236, 0.2);
    padding-top: 2rem;
    text-align: center;
  }

  .footer-bottom p {
    margin-bottom: 0.5rem;
    color: var(--color-background);
    font-size: 0.875rem;
    opacity: 0.6;
  }

  .footer-bottom p:last-child {
    margin-bottom: 0;
  }

  .credits a {
    color: var(--color-earth);
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .credits a:hover {
    opacity: 0.8;
  }

  @media (max-width: 767px) {
    .eleahora-footer {
      padding-top: 4.5rem;
    }

    .brand-slogan {
      max-width: 100%;
    }
  }
</style>
