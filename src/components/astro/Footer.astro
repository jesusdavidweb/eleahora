---
import MeditationModal from '../svelte/MeditationModal.svelte';
import { getSiteConfig } from '../../lib/keystatic';

const currentYear = new Date().getFullYear();
const site = await getSiteConfig();

const whatsappNumber = site?.phoneWhatsapp ?? '+34605373782';
const calLink = site?.calLink ?? 'https://cal.eu/eleahora/sesiones';
const instagramUrl = site?.instagramUrl ?? 'https://www.instagram.com/eleahora/';
const insightUrl = site?.insightTimerUrl ?? 'https://insighttimer.com/eleahora';
---

<footer class="eleahora-footer">
  <div class="footer-container max-w-screen">
    <div class="footer-grid">
      <div class="footer-brand">
        <img src="/images/logo-white.png" alt="Eleahora" class="footer-logo" />
        <p class="brand-slogan text-accent">Soy la voz que te recuerda que estás aquí.</p>
        <button
          class="footer-meditation-cta"
          type="button"
          data-meditation-modal-trigger
          aria-label="Abrir meditación gratuita de Insight Timer en un pop-up"
        >
          Escuchar meditación gratuita
        </button>
      </div>

      <div class="footer-links">
        <h3 class="footer-title">Explora</h3>
        <nav aria-label="Footer Navigation">
          <ul>
            <li><a href="/">Inicio</a></li>
            <li><a href="/about">Sobre Mí</a></li>
            <li><a href="/#manifiesto">Manifiesto</a></li>
            <li><a href="/sesiones">Sesiones y servicios</a></li>
            <li><a href="/workshop-empresas">Workshop Empresas</a></li>
            <li><a href="/#mindfulness">Mindfulness</a></li>
            <li><a href="/contacto">Contacto</a></li>
          </ul>
        </nav>
      </div>

      <div class="footer-contact">
        <h3 class="footer-title">Conecta</h3>
        <ul>
          <li><a href={calLink} target="_blank" rel="noopener noreferrer">Agenda una Sesión</a></li>
          <li><a href={instagramUrl} target="_blank" rel="noopener noreferrer">Instagram</a></li>
          <li><a href="https://www.linkedin.com/in/maria-eleonora-corallo-16266165/" target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
          <li><a href={insightUrl} target="_blank" rel="noopener noreferrer">Meditaciones Guiadas</a></li>
          <li><a href={`https://wa.me/${whatsappNumber.replace(/[^0-9+]/g, '')}`} target="_blank" rel="noopener noreferrer">WhatsApp</a></li>
        </ul>
      </div>

      <div class="footer-legal-col">
        <h3 class="footer-title">Legal</h3>
        <nav aria-label="Legal Navigation">
          <ul>
            <li><a href="/legal/aviso-legal">Aviso Legal</a></li>
            <li><a href="/legal/politica-de-privacidad">Privacidad</a></li>
            <li><a href="/legal/politica-de-cookies">Cookies</a></li>
          </ul>
        </nav>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} Eleahora. Todos los derechos reservados.</p>
      <p class="credits">
        Hecho con amor 🤍 por <a href="http://amorchihouse.com/" target="_blank" rel="noopener noreferrer">Amorchi House</a> y <a href="https://jesusdavid.net/" target="_blank" rel="noopener noreferrer">@jesusdavidweb</a>
      </p>
    </div>
  </div>
</footer>

<MeditationModal client:idle />
