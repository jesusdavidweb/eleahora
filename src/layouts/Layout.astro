---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Header from '../components/astro/Header.astro';
import Footer from '../components/astro/Footer.astro';
import { getSiteConfig } from '../lib/keystatic';

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  canonicalUrl?: string;
}

const SITE_URL = 'https://eleahora.com';

// Keystatic: configuración global del sitio
const siteConfig = await getSiteConfig();

const {
  title,
  description = siteConfig?.siteDescription ?? 'Terapia Transpersonal y Meditación con Eleahora. Acompañamiento terapéutico con PNL, Mindfulness y conexión espiritual para volver al presente.',
  ogTitle = title,
  ogImage = '/images/OG-images-eleahora-02.png',
  ogType = 'website',
  noindex = false,
  canonicalUrl = Astro.url.pathname,
} = Astro.props;

const canonicalHref = `${SITE_URL}${canonicalUrl}`;
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : `${SITE_URL}${ogImage}`;

// Keystatic: colores dinámicos desde CMS
const colors = {
  background:   siteConfig?.colorBackground   ?? '#fdfbec',
  primaryDark:  siteConfig?.colorPrimaryDark  ?? '#3b2639',
  accentRed:    siteConfig?.colorAccentRed    ?? '#8c0703',
  accentPurple: siteConfig?.colorAccentPurple ?? '#6d4492',
  earth:        siteConfig?.colorEarth        ?? '#bb896b',
  sage:         siteConfig?.colorSage         ?? '#566443',
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/images/favicon.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Primario -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalHref} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Eleahora" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogTitle} />

    <!-- Twitter / X Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />
    <meta name="twitter:image:alt" content={ogTitle} />

    <ClientRouter />

    <!-- Dynamic theme color: set synchronously to prevent FOUC on hard reload -->
    <script is:inline define:vars={{ themeColors: [colors.accentRed, colors.primaryDark, colors.sage] }}>
      (function () {
        var color = themeColors[Math.floor(Math.random() * themeColors.length)];
        document.documentElement.style.setProperty('--color-theme-dynamic', color);
      })();
    </script>
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
  </body>
</html>

<script>
  // Scroll to top al navegar entre páginas distintas.
  // astro:after-swap se dispara cuando el nuevo DOM ya reemplazó al anterior
  // pero antes de que se ejecute astro:page-load, así el scroll ocurre
  // antes de que la transición de entrada sea visible.
  document.addEventListener('astro:after-swap', () => {
    // Solo scroll al top si no hay un hash en la URL (ej. /#manifiesto)
    if (!window.location.hash) {
      window.scrollTo({ top: 0, left: 0, behavior: 'instant' });
    }
  });

  // Actualizar el enlace activo del navbar tras cada navegación SPA
  function updateActiveNav() {
    const pathname = window.location.pathname;
    const navLinks = document.querySelectorAll('.nav-links a, .mobile-nav-links a');

    navLinks.forEach((link) => {
      const anchor = link as HTMLAnchorElement;
      const href = anchor.getAttribute('href') ?? '';

      // Eliminar clase active de todos
      anchor.classList.remove('active');

      // Asignar active según la ruta actual
      if (href === pathname) {
        anchor.classList.add('active');
      } else if (pathname === '/' && href === '/') {
        anchor.classList.add('active');
      }
    });
  }

  // Ejecutar en la primera carga y tras cada transición
  document.addEventListener('astro:page-load', updateActiveNav);

  // Cambiar color dinámico en cada navegación SPA
  function applyRandomThemeColor() {
    const root = getComputedStyle(document.documentElement);
    const colors = [
      root.getPropertyValue('--color-accent-red').trim(),
      root.getPropertyValue('--color-primary-dark').trim(),
      root.getPropertyValue('--color-sage').trim(),
    ];
    const color = colors[Math.floor(Math.random() * colors.length)];
    document.documentElement.style.setProperty('--color-theme-dynamic', color);
  }
  document.addEventListener('astro:page-load', applyRandomThemeColor);
</script>

<style define:vars={{
  colorBackground: colors.background,
  colorPrimaryDark: colors.primaryDark,
  colorAccentRed: colors.accentRed,
  colorAccentPurple: colors.accentPurple,
  colorEarth: colors.earth,
  colorSage: colors.sage,
}}>
  :root {
    --color-background: var(--colorBackground);
    --color-primary-dark: var(--colorPrimaryDark);
    --color-accent-red: var(--colorAccentRed);
    --color-accent-purple: var(--colorAccentPurple);
    --color-earth: var(--colorEarth);
    --color-sage: var(--colorSage);
  }
</style>
