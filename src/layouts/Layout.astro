---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Header from '../components/astro/Header.astro';
import Footer from '../components/astro/Footer.astro';
import { getSiteConfig } from '../lib/keystatic';

interface Props {
  title?: string;
  description?: string;
  ogTitle?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  canonicalUrl?: string;
}

const SITE_URL = 'https://eleahora.com';

// Leer config global desde Keystatic
const siteConfig = await getSiteConfig();

const {
  title = siteConfig?.siteTitle ?? 'Eleahora | Terapia Transpersonal y Meditación en Madrid',
  description = siteConfig?.siteDescription ?? 'Terapia Transpersonal, Meditación y Mindfulness con Maria Eleonora Corallo.',
  ogTitle = title,
  ogImage = siteConfig?.ogImage ?? '/images/OG-images-eleahora-01.jpg',
  ogType = 'website',
  noindex = false,
  canonicalUrl = Astro.url.pathname,
} = Astro.props;

const canonicalHref = `${SITE_URL}${canonicalUrl}`;
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : `${SITE_URL}${ogImage}`;

// Colores CSS dinámicos desde Keystatic (con fallback a los valores del brand)
const colors = {
  background:    siteConfig?.colorBackground    ?? '#fdfbec',
  primaryDark:   siteConfig?.colorPrimaryDark   ?? '#3b2639',
  accentRed:     siteConfig?.colorAccentRed     ?? '#8c0703',
  accentPurple:  siteConfig?.colorAccentPurple  ?? '#6d4492',
  earth:         siteConfig?.colorEarth         ?? '#bb896b',
  sage:          siteConfig?.colorSage          ?? '#566443',
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/images/favicon.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Primario -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalHref} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Eleahora" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogTitle} />

    <!-- Twitter / X Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />
    <meta name="twitter:image:alt" content={ogTitle} />

    <ClientRouter />

    <!-- Colores de marca desde Keystatic — sobreescriben las variables CSS del global.css -->
    <style define:vars={{
      'color-background':   colors.background,
      'color-primary-dark': colors.primaryDark,
      'color-accent-red':   colors.accentRed,
      'color-accent-purple':colors.accentPurple,
      'color-earth':        colors.earth,
      'color-sage':         colors.sage,
    }}>
      :root {
        --color-background:    var(--color-background);
        --color-primary-dark:  var(--color-primary-dark);
        --color-accent-red:    var(--color-accent-red);
        --color-accent-purple: var(--color-accent-purple);
        --color-earth:         var(--color-earth);
        --color-sage:          var(--color-sage);
      }
    </style>

    <!-- Dynamic theme color: set synchronously to prevent FOUC on hard reload -->
    <script is:inline define:vars={{ themeColors: [colors.accentRed, colors.primaryDark, colors.sage] }}>
      (function () {
        var color = themeColors[Math.floor(Math.random() * themeColors.length)];
        document.documentElement.style.setProperty('--color-theme-dynamic', color);
      })();
    </script>
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
  </body>
</html>

<script>
  document.addEventListener('astro:after-swap', () => {
    if (!window.location.hash) {
      window.scrollTo({ top: 0, left: 0, behavior: 'instant' });
    }
  });

  function updateActiveNav() {
    const pathname = window.location.pathname;
    const navLinks = document.querySelectorAll('.nav-links a, .mobile-nav-links a');
    navLinks.forEach((link) => {
      const anchor = link as HTMLAnchorElement;
      const href = anchor.getAttribute('href') ?? '';
      anchor.classList.remove('active');
      if (href === pathname) anchor.classList.add('active');
      else if (pathname === '/' && href === '/') anchor.classList.add('active');
    });
  }

  document.addEventListener('astro:page-load', updateActiveNav);

  const THEME_COLORS = ['#8c0703', '#3b2639', '#566443'];
  function applyRandomThemeColor() {
    const color = THEME_COLORS[Math.floor(Math.random() * THEME_COLORS.length)];
    document.documentElement.style.setProperty('--color-theme-dynamic', color);
  }
  document.addEventListener('astro:page-load', applyRandomThemeColor);
</script>
