---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Header from '../components/astro/Header.astro';
import Footer from '../components/astro/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  canonicalUrl?: string;
}

const SITE_URL = 'https://eleahora.com';

const {
  title,
  description = 'Terapia Transpersonal y Meditación con Eleahora. Acompañamiento terapéutico con PNL, Mindfulness y conexión espiritual para volver al presente.',
  ogTitle = title,
  ogImage = '/images/OG-images-eleahora-01.jpg',
  ogType = 'website',
  noindex = false,
  canonicalUrl = Astro.url.pathname,
} = Astro.props;

const canonicalHref = `${SITE_URL}${canonicalUrl}`;
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : `${SITE_URL}${ogImage}`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/images/favicon.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Primario -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalHref} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Eleahora" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogTitle} />

    <!-- Twitter / X Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />
    <meta name="twitter:image:alt" content={ogTitle} />

    <ClientRouter />

    <!-- Dynamic theme color: set synchronously to prevent FOUC on hard reload -->
    <script is:inline>
      (function () {
        var THEME_COLORS = ['#8c0703', '#3b2639', '#566443'];
        var color = THEME_COLORS[Math.floor(Math.random() * THEME_COLORS.length)];
        document.documentElement.style.setProperty('--color-theme-dynamic', color);
      })();
    </script>
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
  </body>
</html>

<script>
  // Scroll to top al navegar entre páginas distintas.
  // astro:after-swap se dispara cuando el nuevo DOM ya reemplazó al anterior
  // pero antes de que se ejecute astro:page-load, así el scroll ocurre
  // antes de que la transición de entrada sea visible.
  document.addEventListener('astro:after-swap', () => {
    // Solo scroll al top si no hay un hash en la URL (ej. /#manifiesto)
    if (!window.location.hash) {
      window.scrollTo({ top: 0, left: 0, behavior: 'instant' });
    }
  });

  // Actualizar el enlace activo del navbar tras cada navegación SPA
  function updateActiveNav() {
    const pathname = window.location.pathname;
    const navLinks = document.querySelectorAll('.nav-links a, .mobile-nav-links a');

    navLinks.forEach((link) => {
      const anchor = link as HTMLAnchorElement;
      const href = anchor.getAttribute('href') ?? '';

      // Eliminar clase active de todos
      anchor.classList.remove('active');

      // Asignar active según la ruta actual
      if (href === pathname) {
        anchor.classList.add('active');
      } else if (pathname === '/' && href === '/') {
        anchor.classList.add('active');
      }
    });
  }

  // Ejecutar en la primera carga y tras cada transición
  document.addEventListener('astro:page-load', updateActiveNav);

  // Cambiar color dinámico en cada navegación SPA
  const THEME_COLORS = ['#8c0703', '#3b2639', '#566443'];
  function applyRandomThemeColor() {
    const color = THEME_COLORS[Math.floor(Math.random() * THEME_COLORS.length)];
    document.documentElement.style.setProperty('--color-theme-dynamic', color);
  }
  document.addEventListener('astro:page-load', applyRandomThemeColor);
</script>
