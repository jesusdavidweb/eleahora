:80 {
    root * /usr/src/app/dist
    encode gzip zstd
    file_server {
        precompressed gzip zstd
    }
    # Try to serve requested files or directories, otherwise return 404
    try_files {path} {path}/ =404

    # Handle 404 errors by serving the dedicated 404.html page
    handle_errors {
        @404 {
            expression {err.status_code} == 404
        }
        rewrite @404 /404.html
        file_server
    }

    # Ensure /404 or /404/ always serves the 404 page correctly
    rewrite /404 /404.html
    rewrite /404/ /404.html
    header {
        Strict-Transport-Security max-age=31536000;
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
    }
    @assets path /assets/*
    header @assets Cache-Control "public, max-age=31536000, immutable"
}
