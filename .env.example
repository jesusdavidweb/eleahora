# ============================================
# Variables de Entorno — Keystatic Admin
# ============================================

# Credenciales para acceder al panel de admin de Keystatic (/keystatic)
# Autenticación Basic Auth
KEYSTATIC_USER=admin
KEYSTATIC_PASSWORD=tu_contraseña_segura_aqui

# Token de GitHub para guardar contenido desde Keystatic
# Se requiere scope 'repo' para escribir en el repositorio
GITHUB_TOKEN=ghp_tu_token_aqui

# OAuth App de GitHub — credenciales para el flujo de login
# Se obtienen de GitHub → Settings → Developer settings → OAuth Apps
KEYSTATIC_GITHUB_CLIENT_ID=Ov23li...
KEYSTATIC_GITHUB_CLIENT_SECRET=tu_client_secret

# Secreto para firmar cookies de sesión de Keystatic
# Generar con: openssl rand -hex 32
# Debe tener al menos 32 caracteres o Keystatic lanzará error 500.
KEYSTATIC_SECRET=

# ============================================
# Notas de despliegue (Dokploy)
# ============================================
# - KEYSTATIC_USER y KEYSTATIC_PASSWORD son obligatorios para el acceso
# - GITHUB_TOKEN es necesario para guardar cambios en el repositorio
# - KEYSTATIC_GITHUB_CLIENT_ID y KEYSTATIC_GITHUB_CLIENT_SECRET
#   se necesitan para el flujo OAuth de GitHub
# - KEYSTATIC_SECRET debe ser un string aleatorio largo (>=32 chars)
#   o Keystatic fallará al crear la sesión tras login.
#
# IMPORTANTE: Estas variables DEBEN estar disponibles durante el BUILD
# (import.meta.env.* se incrusta en bun run build).
# En Dokploy, configúralas en la pestaña Environment y asegúrate de que
# se pasen como build args al Dockerfile.
