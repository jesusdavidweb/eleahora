# GitHub Personal Access Token para Keystatic Cloud Reader
# Crear en: https://github.com/settings/tokens
# Scope necesario: repo (o contents:read sobre jesusdavidweb/eleahora)
# Permite que el servidor SSR lea contenido directamente desde GitHub
# en cada request, sin necesidad de rebuild del contenedor.
GITHUB_PAT=github_pat_xxxxxxxxxxxxxxxxxxxx

# Resend API Key para el envío de emails del formulario de contacto
# Crear en: https://resend.com/api-keys
# Dominio verificado: eleahora.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
